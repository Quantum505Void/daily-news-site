---
interface Props {
  title?: string;
}
const { title = "小新日报" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="小新日报 · 每日自动生成的新闻简报" />
    <meta name="theme-color" content="#0d0d0d" />
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/daily-news-site/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/daily-news-site/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/daily-news-site/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/daily-news-site/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="小新日报" />
    <!-- OG -->
    <meta property="og:title" content="小新日报" />
    <meta property="og:description" content="每日自动生成的新闻简报 · 科技 财经 军事 汽车 旅游" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/daily-news-site/icon-512.png" />
    <link rel="manifest" href="/daily-news-site/site.webmanifest" />
    <style is:global>
      @import "@fontsource-variable/inter";

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0d0d0d;
        --bg2: #161616;
        --bg3: #1e1e1e;
        --bg4: #252525;
        --border: #2a2a2a;
        --text: #d8d8d8;
        --text2: #888;
        --text3: #555;
        --accent: #e74c3c;
        --heading: #f0f0f0;
        --link: #60a5fa;
        --radius: 10px;
        --font: 'Inter Variable', -apple-system, "PingFang SC",
          "Microsoft YaHei", "Helvetica Neue", sans-serif;
      }

      /* ── Dark theme defaults (root) ── */
      :root {
        --header-bg: linear-gradient(135deg, #0d0d1a 0%, #111827 60%, #0f1f3d 100%);
        --search-bg: rgba(255,255,255,0.06);
        --search-border: #252f45;
        --summary-bg: linear-gradient(135deg, #111827 0%, #0f1f3d 100%);
        --summary-border: #1e2d4a;
        --summary-text: #b8cce8;
        --breaking-bg: #1a0f0f;
        --breaking-hover: #201313;
        --major-bg: #1a1208;
        --major-hover: #201608;
      }

      /* ── Light theme overrides ── */
      [data-theme="light"] {
        --bg: #f5f5f5;
        --bg2: #ffffff;
        --bg3: #ebebeb;
        --bg4: #e0e0e0;
        --border: #d0d0d0;
        --text: #222222;
        --text2: #555555;
        --text3: #999999;
        --heading: #111111;
        --link: #1d4ed8;
        --header-bg: linear-gradient(135deg, #e8eaf0 0%, #dde2ec 60%, #d0d8ec 100%);
        --search-bg: rgba(0,0,0,0.06);
        --search-border: #b0bcd4;
        --summary-bg: linear-gradient(135deg, #eef2fa 0%, #e4eaf8 100%);
        --summary-border: #c0cce8;
        --summary-text: #2a3a5a;
        --breaking-bg: #fff0f0;
        --breaking-hover: #ffe0e0;
        --major-bg: #fff8f0;
        --major-hover: #ffeed8;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font);
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        font-size: 15px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }

      /* ── Read progress bar ── */
      #progress-bar {
        position: fixed;
        top: 0; left: 0;
        height: 3px;
        width: 0%;
        background: linear-gradient(90deg, #e74c3c, #f39c12);
        z-index: 9999;
        transition: width 0.1s linear;
        pointer-events: none;
      }

      ::-webkit-scrollbar { width: 4px; height: 4px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }

      a { color: var(--link); text-decoration: none; }
      a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <div id="progress-bar"></div>
    <slot />
    <script>
      // ── 主题 ──
      const html = document.documentElement;
      const saved = localStorage.getItem("theme");
      const preferLight = window.matchMedia("(prefers-color-scheme: light)").matches;
      if (saved === "light" || (!saved && preferLight)) html.setAttribute("data-theme", "light");

      // ── 进度条 ──
      const bar = document.getElementById("progress-bar")!;
      window.addEventListener("scroll", () => {
        const h = document.documentElement;
        const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
        bar.style.width = `${Math.min(pct, 100)}%`;
      }, { passive: true });

      // Service Worker
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/daily-news-site/sw.js");
      }
    </script>
  </body>
</html>
