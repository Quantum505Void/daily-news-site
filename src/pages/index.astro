---
import Base from "../layouts/Base.astro";
---

<Base title="小新日报">
  <header class="site-header">
    <div class="logo-block">
      <div class="logo">🗞️ 小新<span>日报</span></div>
      <div class="tagline">新闻 · 财经 · 科技 · 汽车 · 旅游 · 娱乐</div>
    </div>
    <div class="search-wrap">
      <input
        id="searchInput"
        type="text"
        placeholder="搜索日报内容..."
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-icon">⌕</span>
      <button id="searchClear" class="search-clear" style="display:none" aria-label="清空">✕</button>
    </div>
    <button class="theme-toggle" id="themeToggle" title="切换主题">🌙</button>
  </header>

  <div class="layout">
    <nav class="sidebar" id="sidebar">
      <span class="sidebar-label">历史</span>
    </nav>
    <main class="main" id="main">
      <div class="state-msg"><div class="icon">⏳</div><p>加载中...</p></div>
    </main>
  </div>

  <footer class="page-footer">
    由小新 🔧 自动生成 ·
    <a href="https://github.com/Quantum505Void/daily-news-site" target="_blank" rel="noopener">GitHub</a>
    · <span id="buildTime"></span>
    · <span id="visitCount" title="累计访问次数">👁 --</span>
  </footer>

  <button class="back-top" id="backTop" aria-label="回到顶部" title="回到顶部">↑</button>
</Base>

<style>
  /* ── Header ── */
  .site-header {
    background: var(--header-bg);
    padding: 10px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 200;
    flex-wrap: wrap;
  }
  /* ── logo ── */
  .logo { font-size: 22px; font-weight: 900; color: var(--accent); line-height: 1.1; letter-spacing: -0.5px; }
  .logo span { color: var(--heading); }   /* light 主题下也清晰 */
  .logo-block { display: flex; flex-direction: column; gap: 2px; flex-shrink: 0; }
  .tagline { font-size: 11px; color: var(--text2); letter-spacing: 0.5px; opacity: 0.7; }

  .search-wrap {
    position: relative;
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .search-clear {
    position: absolute; right: 8px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: var(--text3); font-size: 12px;
    display: flex; align-items: center; justify-content: center;
    width: 18px; height: 18px; border-radius: 50%;
    padding: 0; line-height: 1;
    transition: background 0.15s, color 0.15s;
  }
  .search-clear:hover { background: var(--bg4); color: var(--text); }
  #searchInput {
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    border-radius: 20px;
    color: var(--text);
    font-size: 13px;
    font-family: var(--font);
    padding: 6px 14px 6px 32px;
    width: 200px;
    outline: none;
    transition: border-color 0.2s, width 0.3s, background 0.2s;
  }
  #searchInput:focus { border-color: var(--accent); background: var(--search-bg); width: 280px; }
  #searchInput::placeholder { color: var(--text3); }
  .search-icon {
    position: absolute; left: 10px; top: 50%;
    transform: translateY(-50%);
    color: var(--text3); font-size: 16px; pointer-events: none;
  }

  .theme-toggle {
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    border-radius: 8px;
    padding: 5px 9px;
    font-size: 15px;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s;
    line-height: 1;
  }
  .theme-toggle:hover { background: var(--bg3); }

  /* ── Layout ── */
  .layout {
    display: flex;
    max-width: 1280px;
    margin: 0 auto;
    min-height: calc(100vh - 53px - 52px);
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 130px;
    flex-shrink: 0;
    padding: 16px 8px;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 53px;
    height: calc(100vh - 53px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar-label {
    font-size: 10px; color: var(--text3);
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0 8px 8px;
  }

  /* ── Main ── */
  /* 已合并到 section-toggle 后的 .main 定义 */

  /* ── State msgs ── */
  :global(.state-msg) { text-align: center; padding: 80px 20px; color: var(--text2); }
  :global(.state-msg .icon) { font-size: 40px; margin-bottom: 12px; }

  /* ── Footer ── */
  .page-footer {
    text-align: center; padding: 18px;
    color: var(--text3); font-size: 12px;
    border-top: 1px solid var(--border);
  }

  /* ── Mobile ── */
  @media (max-width: 680px) {
    .search-wrap { margin-left: 0; width: 100%; }
    #searchInput { width: 100%; }
    #searchInput:focus { width: 100%; }
    .tagline { font-size: 10px; }
    .sidebar {
      width: 100%; height: auto; position: static;
      flex-direction: row; flex-wrap: nowrap;
      overflow-x: auto; padding: 8px 12px;
      border-right: none; border-bottom: 1px solid var(--border); gap: 4px;
    }
    .sidebar-label { display: none; }
    .layout { flex-direction: column; }
  }
</style>

<script>
  import type { Digest, Manifest } from "../types";
  import Fuse from "fuse.js";

  const BASE = (import.meta.env.BASE_URL ?? "/").replace(/\/?$/, "/");
  const TAG_COLORS: Record<string, string> = {
    突发: "tag-breaking", 重磅: "tag-major", 分析: "tag-analysis",
    趋势: "tag-trend", 观察: "tag-watch", 机会: "tag-opportunity",
    提醒: "tag-alert", 知识库: "tag-knowledge",
  };

  const WIDE_SECTIONS = new Set(["highlight"]);

  let dates: string[] = [];
  let cache: Record<string, Digest> = {};

  interface SearchDoc {
    date: string; secId: string; secTitle: string;
    title: string; body: string; tag: string; url: string;
  }
  let fuse: Fuse<SearchDoc> | null = null;

  async function loadSearchIndex() {
    try {
      const r = await fetch(`${BASE}search-index.json?t=${Date.now()}`);
      if (!r.ok) return;
      const docs: SearchDoc[] = await r.json();
      fuse = new Fuse(docs, {
        keys: [{ name: "title", weight: 2 }, { name: "body", weight: 1 }, { name: "secTitle", weight: 0.5 }],
        threshold: 0.4, includeMatches: true, minMatchCharLength: 2,
      });
    } catch { /* 降级：搜索只能搜已加载的 */ }
  }

  // 降级：从已加载数据建索引
  function buildFallbackIndex() {
    const docs: SearchDoc[] = [];
    for (const [date, d] of Object.entries(cache)) {
      for (const sec of d.sections ?? []) {
        for (const item of sec.items ?? []) {
          docs.push({ date, secId: sec.id, secTitle: sec.title,
            title: item.title, body: (item.body ?? "").slice(0, 100),
            tag: item.tag ?? "", url: item.url ?? "" });
        }
      }
    }
    if (!fuse && docs.length) {
      fuse = new Fuse(docs, {
        keys: [{ name: "title", weight: 2 }, { name: "body", weight: 1 }, { name: "secTitle", weight: 0.5 }],
        threshold: 0.4, includeMatches: true, minMatchCharLength: 2,
      });
    }
  }

  function highlight(text: string, matches: readonly Fuse.FuseResultMatch[] | undefined, key: string): string {
    if (!matches) return text;
    const m = matches.find(m => m.key === key);
    if (!m?.indices?.length) return text;
    let result = "", last = 0;
    for (const [s, e] of m.indices) {
      result += text.slice(last, s) + `<mark>${text.slice(s, e + 1)}</mark>`;
      last = e + 1;
    }
    return result + text.slice(last);
  }

  function tagHtml(tag: string): string {
    if (!tag) return "";
    return `<span class="tag ${TAG_COLORS[tag] ?? "tag-default"}">${tag}</span>`;
  }

  function renderSearchResults(query: string) {
    if (!fuse || !query.trim()) return;
    const results = fuse.search(query, { limit: 20 });
    const main = document.getElementById("main")!;
    if (!results.length) {
      main.innerHTML = `<div class="state-msg"><div class="icon">🔍</div><p>没有找到 "${query}" 的相关内容</p></div>`;
      return;
    }
    const html = results.map(r => {
      const { title, body, secTitle, date, tag, url } = r.item;
      const titleHl = highlight(title, r.matches, "title");
      const bodyHl  = highlight(body,  r.matches, "body");
      const domain = (() => { try { return url ? new URL(url).hostname.replace(/^www\./, "") : ""; } catch { return ""; } })();
      const faviconHtml = domain ? `<img class="card-favicon" src="https://www.google.com/s2/favicons?domain=${domain}&sz=16" width="14" height="14" loading="lazy" onerror="this.style.display='none'">` : "";
      const sourceHtml = url ? `<a class="card-source" href="${url}" target="_blank" rel="noopener">${faviconHtml}${domain || "查看原文"} ↗</a>` : "";
      const titleEl = url
        ? `<a class="card-title-text" href="${url}" target="_blank" rel="noopener">${titleHl}</a>`
        : `<span class="card-title-text">${titleHl}</span>`;
      return `<article class="card" ${url ? `data-url="${url}"` : ""} style="${url ? "cursor:pointer" : ""}">
        <div class="card-meta">${date} · ${secTitle}</div>
        <div class="card-title">${titleEl}${tagHtml(tag)}</div>
        <p class="card-body">${bodyHl}</p>
        <div class="card-footer">${sourceHtml}</div>
      </article>`;
    }).join("");
    main.innerHTML = `
      <div class="search-result-header">🔍 找到 <b>${results.length}</b> 条与 "<b>${query}</b>" 相关的内容</div>
      <div class="cards">${html}</div>`;
  }

  async function fetchManifest(): Promise<string[]> {
    const r = await fetch(`${BASE}manifest.json?t=${Date.now()}`);
    const m: Manifest = await r.json();
    return m.dates ?? [];
  }

  async function fetchDigest(date: string): Promise<Digest> {
    if (cache[date]) return cache[date];
    const r = await fetch(`${BASE}data/${date}.json?t=${Date.now()}`);
    if (!r.ok) throw new Error(`${r.status}`);
    const d: Digest = await r.json();
    cache[date] = d;
    buildFallbackIndex();
    return d;
  }

  function fmtDate(d: string): string {
    const [y, m, day] = d.split("-").map(Number);
    const dow = ["日","一","二","三","四","五","六"][new Date(y, m-1, day).getDay()];
    return `${m}月${day}日 周${dow}`;
  }

  function renderSidebar(selected: string) {
    const nav = document.getElementById("sidebar")!;
    const backToday = selected !== dates[0]
      ? `<button class="back-today-btn" data-date="${dates[0]}">⬆ 今日</button>`
      : "";
    nav.innerHTML = '<span class="sidebar-label">历史</span>' + backToday +
      dates.slice(0, 30).map((d, i) => {
        const active = d === selected ? "active" : "";
        const label = i === 0 ? `今天` : `${d.slice(5).replace("-","月")}日`;
        const [y, mo, day] = d.split("-").map(Number);
        const dow = ["日","一","二","三","四","五","六"][new Date(y, mo-1, day).getDay()];
        const sub = `<span class="date-sub">周${dow}</span>`;
        return `<button class="date-btn ${active}" data-date="${d}">${label}${sub}</button>`;
      }).join("");
    nav.querySelectorAll(".date-btn,.back-today-btn").forEach(btn =>
      btn.addEventListener("click", () => {
        nav.querySelectorAll(".date-btn").forEach(b => b.classList.remove("loading"));
        (btn as HTMLElement).classList.add("loading");
        showDate((btn as HTMLElement).dataset.date!);
      })
    );
  }

  function cardHtml(item: any, isJob: boolean, idx: number, defCollapsed = "card-body--collapsed"): string {
    const domain = (() => {
      try { return item.url ? new URL(item.url).hostname.replace(/^www\./, "") : ""; }
      catch { return ""; }
    })();
    const sourceHtml = domain
      ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener"><img class="card-favicon" src="https://www.google.com/s2/favicons?domain=${domain}&sz=16" width="14" height="14" loading="lazy" onerror="this.style.display='none'">${domain} ↗</a>`
      : item.url ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener">查看原文 ↗</a>` : "";
    const extraClass = isJob ? " card--job"
      : item.tag === "突发" ? " card--breaking"
      : item.tag === "重磅" ? " card--major" : "";
    const num = `<span class="card-num">${idx + 1}</span>`;
    const expandBtn = defCollapsed
      ? `<button class="card-expand">展开 ▾</button>`
      : ``;
    const urlAttr = item.url ? `data-url="${item.url}"` : "";
    const cursorStyle = item.url ? `style="cursor:pointer"` : "";
    return `<article class="card${extraClass}" ${urlAttr} ${cursorStyle}>
      <div class="card-title">${num}<span class="card-title-text">${item.title}</span>${tagHtml(item.tag)}</div>
      <p class="card-body ${defCollapsed}">${item.body}</p>
      <div class="card-footer">${sourceHtml}${expandBtn}</div>
    </article>`;
  }

  function fmtBadge(d: Digest): string {
    const [y, m, day] = (d.date ?? "").split("-").map(Number);
    if (!y) return d.title ?? d.date ?? "";
    const dow = ["日","一","二","三","四","五","六"][new Date(y, m-1, day).getDay()];
    return `${m}月${day}日 · 周${dow}`;
  }

  function renderV2(d: Digest): string {
    const genTime = d.generated_at
      ? new Date(d.generated_at).toLocaleTimeString("zh-CN", { hour: "2-digit", minute: "2-digit", timeZone: "Asia/Shanghai" })
      : "";
    const sections = d.sections ?? [];
    const totalItems = sections.reduce((n, s) => n + (s.items?.length ?? 0), 0);

    const navHtml = sections
      .map(s => `<a class="sec-nav-btn" data-sec="${s.id}" href="#sec-${s.id}">${s.icon} ${s.title}</a>`)
      .join("");

    const sectionsHtml = sections.map(s => {
      const isJob  = s.id === "jobs_hot";
      const isWide = WIDE_SECTIONS.has(s.id);
      const defCollapsed = isWide ? "" : "card-body--collapsed";
      const cards  = (s.items ?? []).map((item, idx) => cardHtml(item, isJob, idx, defCollapsed)).join("");
      const gridClass = isWide ? "cards cards--wide" : "cards cards--grid";
      return `<section class="section${isWide ? " section--wide" : ""}" id="sec-${s.id}">
        <div class="section-heading" style="--sec-color:${s.color}">
          <span class="section-icon">${s.icon}</span>
          <h2 class="section-title">${s.title}</h2>
          <button class="section-toggle" aria-label="折叠板块">▴</button>
        </div>
        <div class="${gridClass}">${cards}</div>
      </section>`;
    }).join("");

    return `
      <div class="digest-header">
        <div class="digest-top">
          <span class="digest-title">🗞️ 小新<b>日报</b></span>
          <span class="digest-badge">${fmtBadge(d)}</span>
        </div>
        ${d.summary ? `<div class="digest-summary"><p class="digest-summary-text">${d.summary}</p></div>` : ""}
        <div class="digest-stats">
          <span>${sections.length} 板块</span>
          <span class="stats-sep">·</span>
          <span>${totalItems} 条资讯</span>
          ${genTime ? `<span class="stats-sep">·</span><span>更新于 ${genTime}</span>` : ""}
        </div>
      </div>
      <nav class="sec-nav" id="secNav">${navHtml}</nav>
      ${sectionsHtml}`;
  }

  async function showDate(date: string) {
    renderSidebar(date);
    location.hash = date;
    const main = document.getElementById("main")!;
    main.classList.remove("main--fadein");
    main.innerHTML = `<div class="skeleton-wrap">
      <div class="skeleton skeleton-hero"></div>
      <div class="skeleton-nav">${Array(7).fill('<div class="skeleton skeleton-pill"></div>').join("")}</div>
      ${Array(3).fill(`<div class="skeleton-section">
        <div class="skeleton skeleton-heading"></div>
        ${Array(3).fill('<div class="skeleton skeleton-card"></div>').join("")}
      </div>`).join("")}
    </div>`;
    try {
      const d = await fetchDigest(date);
      main.innerHTML = renderV2(d);
      // 清掉 loading 状态
      document.querySelectorAll(".date-btn.loading").forEach(b => b.classList.remove("loading"));
      // fade-in
      requestAnimationFrame(() => { main.classList.add("main--fadein"); });
      window.scrollTo({ top: 0, behavior: "instant" });
      initSectionObserver();
    } catch {
      main.innerHTML = '<div class="state-msg"><div class="icon">⚠️</div><p>加载失败，请稍后重试</p></div>';
    }
  }

  // ── sec-nav 滚动高亮 + 精确滚动 ──
  function initSectionObserver() {
    const setActive = (id: string) => {
      document.querySelectorAll<HTMLElement>(".sec-nav-btn").forEach(b =>
        b.classList.toggle("active", b.dataset.sec === id)
      );
    };

    // 精确滚动：计算 sticky header + sec-nav 高度后定位
    document.querySelectorAll<HTMLElement>(".sec-nav-btn").forEach(btn => {
      btn.addEventListener("click", e => {
        e.preventDefault();
        const secId = btn.dataset.sec!;
        const target = document.getElementById(`sec-${secId}`);
        if (!target) return;
        const header = document.querySelector(".site-header") as HTMLElement;
        const nav    = document.getElementById("secNav") as HTMLElement;
        const offset = (header?.offsetHeight ?? 53) + (nav?.offsetHeight ?? 45) + 12;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: "smooth" });
        setActive(secId);
      });
    });

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting)
          setActive(e.target.id.replace("sec-", ""));
      });
    }, { rootMargin: "-15% 0px -55% 0px" });

    document.querySelectorAll(".section").forEach(s => obs.observe(s));

    // 滚到底时强制激活最后一个板块
    window.addEventListener("scroll", () => {
      const atBottom = window.innerHeight + window.scrollY >= document.body.scrollHeight - 60;
      if (!atBottom) return;
      const sections = document.querySelectorAll<HTMLElement>(".section");
      const last = sections[sections.length - 1];
      if (last) setActive(last.id.replace("sec-", ""));
    }, { passive: true });
  }

  // ── 访问计数 ──
  async function trackVisit() {
    try {
      const r = await fetch("https://counterapi.dev/api/xiaoxin-daily-news/visit", { method: "GET" });
      if (!r.ok) return;
      const data = await r.json();
      const el = document.getElementById("visitCount");
      if (el && data?.count != null) {
        el.textContent = `👁 ${data.count.toLocaleString()} 次`;
        el.title = `累计访问 ${data.count.toLocaleString()} 次`;
      }
    } catch { /* 静默失败 */ }
  }

  async function init() {
    // 显示构建时间
    const bt = document.getElementById("buildTime");
    if (bt) bt.textContent = `构建于 ${new Date().toLocaleString("zh-CN", { timeZone: "Asia/Shanghai", month:"numeric", day:"numeric", hour:"2-digit", minute:"2-digit" })}`;
    trackVisit();
    try {
      dates = await fetchManifest();
      if (!dates.length) {
        document.getElementById("sidebar")!.innerHTML = "";
        document.getElementById("main")!.innerHTML =
          '<div class="state-msg"><div class="icon">📭</div><p>还没有日报</p></div>';
        return;
      }
      const hash = location.hash.replace("#", "");
      // 并行加载搜索索引和首屏数据
      await Promise.all([
        loadSearchIndex(),
        showDate(hash && dates.includes(hash) ? hash : dates[0]),
      ]);
    } catch {
      document.getElementById("main")!.innerHTML =
        '<div class="state-msg"><div class="icon">⚠️</div><p>无法加载日报列表</p></div>';
    }
  }

  window.addEventListener("hashchange", () => {
    const d = location.hash.replace("#", "");
    if (d && dates.includes(d)) showDate(d);
  });

  // ── 主题切换 ──
  const themeBtn = document.getElementById("themeToggle")!;
  function applyTheme(light: boolean) {
    const html = document.documentElement;
    // 过渡动画
    html.style.transition = "background 0.3s, color 0.3s";
    html.setAttribute("data-theme", light ? "light" : "dark");
    themeBtn.textContent = light ? "☀️" : "🌙";
    localStorage.setItem("theme", light ? "light" : "dark");
    setTimeout(() => { html.style.transition = ""; }, 350);
  }
  applyTheme(document.documentElement.getAttribute("data-theme") === "light");
  themeBtn.addEventListener("click", () => {
    applyTheme(document.documentElement.getAttribute("data-theme") !== "light");
  });

  // ── 回到顶部 ──
  const backTop = document.getElementById("backTop")!;
  window.addEventListener("scroll", () => {
    backTop.classList.toggle("visible", window.scrollY > 300);
  }, { passive: true });
  backTop.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));

  // ── 事件委托：展开/折叠卡片 + 折叠板块 ──
  document.getElementById("main")!.addEventListener("click", (e) => {
    const t = e.target as HTMLElement;

    // 卡片整行跳转（data-url）
    const cardEl = t.closest(".card[data-url]") as HTMLElement | null;
    if (cardEl && !(t.closest("a,button"))) {
      window.open(cardEl.dataset.url, "_blank", "noopener");
      return;
    }

    // 展开卡片
    const expandBtn = t.closest(".card-expand") as HTMLElement | null;
    if (expandBtn) {
      const body = expandBtn.closest(".card")!.querySelector(".card-body") as HTMLElement;
      const collapsed = body.classList.toggle("card-body--collapsed");
      expandBtn.textContent = collapsed ? "展开 ▾" : "收起 ▴";
      return;
    }

    // 折叠板块
    const toggleBtn = t.closest(".section-toggle") as HTMLElement | null;
    if (toggleBtn) {
      const section = toggleBtn.closest(".section")!;
      const cards = section.querySelector(".cards") as HTMLElement;
      const collapsed = cards.classList.toggle("cards--hidden");
      toggleBtn.textContent = collapsed ? "▾" : "▴";
      toggleBtn.classList.toggle("section-toggle--collapsed", collapsed);
    }
  });

  // ── 搜索 ──
  const searchInput = document.getElementById("searchInput") as HTMLInputElement;
  const searchClear = document.getElementById("searchClear") as HTMLElement;
  let searchTimer: ReturnType<typeof setTimeout>;

  function updateClearBtn() {
    searchClear.style.display = searchInput.value ? "flex" : "none";
  }

  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    updateClearBtn();
    const q = searchInput.value.trim();
    if (!q) {
      const current = location.hash.replace("#", "") || dates[0];
      if (current) showDate(current);
      return;
    }
    searchTimer = setTimeout(() => renderSearchResults(q), 300);
  });
  searchInput.addEventListener("keydown", e => {
    if (e.key === "Escape") {
      searchInput.value = "";
      updateClearBtn();
      searchInput.dispatchEvent(new Event("input"));
    }
  });
  searchClear.addEventListener("click", () => {
    searchInput.value = "";
    updateClearBtn();
    searchInput.dispatchEvent(new Event("input"));
    searchInput.focus();
  });

  // `/` 键聚焦搜索框
  document.addEventListener("keydown", e => {
    if (e.key === "/" && document.activeElement !== searchInput) {
      e.preventDefault();
      searchInput.focus();
      searchInput.select();
    }
  });

  // ── 离线 Toast ──
  function showToast(msg: string, duration = 3500) {
    let t = document.getElementById("offlineToast") as HTMLElement;
    if (!t) {
      t = document.createElement("div");
      t.id = "offlineToast";
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.classList.add("toast--show");
    setTimeout(() => t.classList.remove("toast--show"), duration);
  }
  window.addEventListener("offline", () => showToast("📡 已离线，显示缓存内容"));
  window.addEventListener("online",  () => showToast("✅ 网络已恢复"));

  init();
</script>

