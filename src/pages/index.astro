  // ── 节假日数据（国内法定，纯前端） ──
  function getNextHoliday(): {name:string; date:string; days:number} | null {
    const HOLIDAYS: {name:string; date:string}[] = [
      {name:"清明节",   date:"2026-04-05"},
      {name:"劳动节",   date:"2026-05-01"},
      {name:"端午节",   date:"2026-06-20"},
      {name:"中秋节",   date:"2026-10-01"},
      {name:"国庆节",   date:"2026-10-01"},
      {name:"元旦",     date:"2027-01-01"},
      {name:"春节",     date:"2027-01-28"},
    ];
    const now = Date.now();
    for (const h of HOLIDAYS) {
      const ms = new Date(h.date).getTime() - now;
      if (ms > 0) return { name: h.name, date: h.date, days: Math.ceil(ms / 86400000) };
    }
    return null;
  }

