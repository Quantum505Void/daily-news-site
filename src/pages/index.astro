---
import Base from "../layouts/Base.astro";
---

<Base title="小新日报">
  <header class="site-header">
    <div class="logo-block">
      <div class="logo">🗞️ 小新<span>日报</span></div>
      <div class="tagline">新闻 · 财经 · 科技 · 汽车 · 旅游 · 娱乐</div>
    </div>
    <div class="search-wrap">
      <input
        id="searchInput"
        type="text"
        placeholder="搜索日报内容..."
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-icon">⌕</span>
      <kbd class="search-kbd" id="searchKbd">⌘K</kbd>
      <button id="searchClear" class="search-clear" style="display:none" aria-label="清空">✕</button>
    </div>
    <button class="theme-toggle" id="themeToggle" title="切换主题">🌙</button>
  </header>

  <div class="layout">
    <nav class="sidebar" id="sidebar">
      <span class="sidebar-label">历史</span>
    </nav>
    <main class="main" id="main">
      <div class="state-msg"><div class="icon">⏳</div><p>加载中...</p></div>
    </main>
  </div>

  <footer class="page-footer">
    <div class="footer-inner">
      <span>由小新 🔧 自动生成</span>
      <span class="footer-sep">·</span>
      <a href="https://github.com/Quantum505Void/daily-news-site" target="_blank" rel="noopener">GitHub</a>
      <span class="footer-sep">·</span>
      <span id="buildTime"></span>
    </div>
    <div class="footer-stats">
      <span class="footer-stat">👁 <span id="vercount_value_site_pv" class="footer-stat-val">--</span> 次浏览</span>
      <span class="footer-sep">·</span>
      <span class="footer-stat">👤 <span id="vercount_value_site_uv" class="footer-stat-val">--</span> 位访客</span>
    </div>
  </footer>

  <button class="back-top" id="backTop" aria-label="回到顶部" title="回到顶部">↑</button>

  <!-- AI 问答浮窗 -->
  <div class="ai-fab-wrap">
    <button class="ai-fab" id="aiFab" title="AI 问答">
      <span class="ai-fab-icon">✦</span>
    </button>
    <button class="tts-fab" id="ttsFab" title="朗读今日日报">
      <span>🔊</span>
    </button>
  </div>

  <div class="ai-panel" id="aiPanel">
    <div class="ai-panel-header">
      <span class="ai-panel-title">✦ AI 问答</span>
      <span class="ai-panel-sub" id="aiPanelSub">GPT-5-mini · 基于今日日报</span>
      <button class="ai-panel-close" id="aiPanelClose">✕</button>
    </div>
    <div class="ai-messages" id="aiMessages">
      <div class="ai-msg ai-msg--hint">你好！我已读完今日日报，有什么想聊的？<br><span class="ai-hint-examples">试试：今天最重要的新闻是什么？科技领域有什么大事？</span></div>
    </div>
    <div class="ai-input-row">
      <input class="ai-input" id="aiInput" placeholder="问我任何关于今日日报的问题..." autocomplete="off" />
      <button class="ai-send" id="aiSend">发送</button>
    </div>
  </div>
</Base>

<style>
  /* ── Header ── */
  .site-header {
    background: var(--header-bg);
    padding: 10px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 200;
    flex-wrap: wrap;
  }
  /* ── logo ── */
  .logo { font-size: 22px; font-weight: 900; color: var(--accent); line-height: 1.1; letter-spacing: -0.5px; }
  .logo span { color: var(--heading); }   /* light 主题下也清晰 */
  .logo-block { display: flex; flex-direction: column; gap: 2px; flex-shrink: 0; }
  .tagline { font-size: 11px; color: var(--text2); letter-spacing: 0.5px; opacity: 0.7; }

  .search-wrap {
    position: relative;
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .search-clear {
    position: absolute; right: 8px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: var(--text3); font-size: 12px;
    display: flex; align-items: center; justify-content: center;
    width: 18px; height: 18px; border-radius: 50%;
    padding: 0; line-height: 1;
    transition: background 0.15s, color 0.15s;
  }
  .search-clear:hover { background: var(--bg4); color: var(--text); }
  .search-kbd {
    position: absolute; right: 10px; top: 50%;
    transform: translateY(-50%);
    font-size: 10px; color: var(--text3);
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 4px; padding: 1px 5px;
    pointer-events: none; font-family: var(--font);
    transition: opacity 0.15s;
  }
  #searchInput:focus ~ .search-kbd { opacity: 0; }
  #searchInput {
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    border-radius: 20px;
    color: var(--text);
    font-size: 13px;
    font-family: var(--font);
    padding: 6px 14px 6px 32px;
    width: 200px;
    outline: none;
    transition: border-color 0.2s, width 0.3s, background 0.2s;
  }
  #searchInput:focus { border-color: var(--accent); background: var(--search-bg); width: 280px; }
  #searchInput::placeholder { color: var(--text3); }
  .search-icon {
    position: absolute; left: 10px; top: 50%;
    transform: translateY(-50%);
    color: var(--text3); font-size: 16px; pointer-events: none;
  }

  .theme-toggle {
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    border-radius: 8px;
    padding: 5px 9px;
    font-size: 15px;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s;
    line-height: 1;
  }
  .theme-toggle:hover { background: var(--bg3); }

  /* ── Layout ── */
  .layout {
    display: flex;
    max-width: 1280px;
    margin: 0 auto;
    min-height: calc(100vh - 53px - 52px);
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 130px;
    flex-shrink: 0;
    padding: 16px 8px;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 53px;
    height: calc(100vh - 53px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar-label {
    font-size: 10px; color: var(--text3);
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0 8px 8px;
  }

  /* ── Main ── */
  /* 已合并到 section-toggle 后的 .main 定义 */

  /* ── State msgs ── */
  :global(.state-msg) { text-align: center; padding: 80px 20px; color: var(--text2); }
  :global(.state-msg .icon) { font-size: 40px; margin-bottom: 12px; }

  /* ── Footer ── */
  .page-footer {
    text-align: center; padding: 20px 18px;
    color: var(--text3); font-size: 12px;
    border-top: 1px solid var(--border);
    display: flex; flex-direction: column; gap: 6px; align-items: center;
  }
  .footer-inner { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center; }
  .footer-sep { opacity: 0.35; }
  .footer-stats { display: flex; align-items: center; gap: 8px; }
  .footer-stat { display: flex; align-items: center; gap: 3px; }
  .footer-stat-val { font-weight: 600; color: var(--text2); transition: color 0.3s; }

  /* ── Mobile ── */
  @media (max-width: 680px) {
    .search-wrap { margin-left: 0; width: 100%; }
    #searchInput { width: 100%; }
    #searchInput:focus { width: 100%; }
    .tagline { font-size: 10px; }
    .sidebar {
      width: 100%; height: auto; position: static;
      flex-direction: row; flex-wrap: nowrap;
      overflow-x: auto; padding: 8px 12px;
      border-right: none; border-bottom: 1px solid var(--border); gap: 4px;
    }
    .sidebar-label { display: none; }
    .layout { flex-direction: column; }
  }
</style>

<script>
  import type { Digest, Manifest } from "../types";
  import Fuse from "fuse.js";

  const BASE = (import.meta.env.BASE_URL ?? "/").replace(/\/?$/, "/");
  const TAG_COLORS: Record<string, string> = {
    突发: "tag-breaking", 重磅: "tag-major", 分析: "tag-analysis",
    趋势: "tag-trend", 观察: "tag-watch", 机会: "tag-opportunity",
    提醒: "tag-alert", 知识库: "tag-knowledge",
  };

  const WIDE_SECTIONS = new Set(["highlight"]);

  // ── 收藏夹（localStorage） ──
  const FAVE_KEY = "xiaoxin_faves";
  function getFaves(): Set<string> {
    try { return new Set(JSON.parse(localStorage.getItem(FAVE_KEY) ?? "[]")); }
    catch { return new Set(); }
  }
  function saveFaves(s: Set<string>) {
    localStorage.setItem(FAVE_KEY, JSON.stringify([...s]));
  }
  function toggleFave(url: string): boolean {
    const s = getFaves(); const had = s.has(url);
    had ? s.delete(url) : s.add(url); saveFaves(s); return !had;
  }
  function isFaved(url: string): boolean { return getFaves().has(url); }

  // 渲染收藏页
  function renderFavesPage() {
    const faves = getFaves();
    const main = document.getElementById("main")!;
    if (!faves.size) {
      main.innerHTML = `<div class="state-msg"><div class="icon">⭐</div><p>还没有收藏，点击卡片右下角 ☆ 收藏</p></div>`;
      return;
    }
    // 从 cache 里找收藏的条目
    const items: Array<{ title: string; body: string; url: string; tag: string; secTitle: string; date: string }> = [];
    for (const [date, d] of Object.entries(cache)) {
      for (const sec of d.sections ?? []) {
        for (const item of sec.items ?? []) {
          if (item.url && faves.has(item.url)) {
            items.push({ ...item, secTitle: sec.title, date });
          }
        }
      }
    }
    if (!items.length) {
      main.innerHTML = `<div class="state-msg"><div class="icon">⭐</div><p>收藏的条目已不在缓存中，请先加载对应日期</p></div>`;
      return;
    }
    const html = items.map(item => {
      const domain = (() => { try { return item.url ? new URL(item.url).hostname.replace(/^www\./,"") : ""; } catch { return ""; } })();
      const src = domain ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener"><img class="card-favicon" src="https://www.google.com/s2/favicons?domain=${domain}&sz=16" width="14" height="14" loading="lazy" onerror="this.style.display='none'">${domain} ↗</a>` : "";
      return `<article class="card" data-url="${item.url}" style="cursor:pointer">
        <div class="card-meta">${item.date} · ${item.secTitle}</div>
        <div class="card-title"><span class="card-title-text">${item.title}</span>${tagHtml(item.tag)}</div>
        <div class="card-body-wrap"><p class="card-body">${item.body}</p></div>
        <div class="card-footer">${src}<button class="fave-btn faved" data-url="${item.url}" title="取消收藏">★</button></div>
      </article>`;
    }).join("");
    main.innerHTML = `<div class="faves-header">⭐ 已收藏 ${items.length} 条</div><div class="cards cards--grid">${html}</div>`;
    main.classList.add("main--fadein");
  }

  let dates: string[] = [];
  let cache: Record<string, Digest> = {};

  interface SearchDoc {
    date: string; secId: string; secTitle: string;
    title: string; body: string; tag: string; url: string;
  }
  let fuse: Fuse<SearchDoc> | null = null;

  async function loadSearchIndex() {
    try {
      const r = await fetch(`${BASE}search-index.json?t=${Date.now()}`);
      if (!r.ok) return;
      const docs: SearchDoc[] = await r.json();
      fuse = new Fuse(docs, {
        keys: [{ name: "title", weight: 2 }, { name: "body", weight: 1 }, { name: "secTitle", weight: 0.5 }],
        threshold: 0.4, includeMatches: true, minMatchCharLength: 2,
      });
    } catch { /* 降级：搜索只能搜已加载的 */ }
  }

  // 降级：从已加载数据建索引
  function buildFallbackIndex() {
    const docs: SearchDoc[] = [];
    for (const [date, d] of Object.entries(cache)) {
      for (const sec of d.sections ?? []) {
        for (const item of sec.items ?? []) {
          docs.push({ date, secId: sec.id, secTitle: sec.title,
            title: item.title, body: (item.body ?? "").slice(0, 100),
            tag: item.tag ?? "", url: item.url ?? "" });
        }
      }
    }
    if (!fuse && docs.length) {
      fuse = new Fuse(docs, {
        keys: [{ name: "title", weight: 2 }, { name: "body", weight: 1 }, { name: "secTitle", weight: 0.5 }],
        threshold: 0.4, includeMatches: true, minMatchCharLength: 2,
      });
    }
  }

  function highlight(text: string, matches: readonly Fuse.FuseResultMatch[] | undefined, key: string): string {
    if (!matches) return text;
    const m = matches.find(m => m.key === key);
    if (!m?.indices?.length) return text;
    let result = "", last = 0;
    for (const [s, e] of m.indices) {
      result += text.slice(last, s) + `<mark>${text.slice(s, e + 1)}</mark>`;
      last = e + 1;
    }
    return result + text.slice(last);
  }

  function tagHtml(tag: string): string {
    if (!tag) return "";
    return `<span class="tag ${TAG_COLORS[tag] ?? "tag-default"}">${tag}</span>`;
  }

  function renderSearchResults(query: string) {
    if (!fuse || !query.trim()) return;
    const results = fuse.search(query, { limit: 20 });
    const main = document.getElementById("main")!;
    if (!results.length) {
      main.innerHTML = `<div class="state-msg"><div class="icon">🔍</div><p>没有找到 "${query}" 的相关内容</p></div>`;
      return;
    }
    const html = results.map(r => {
      const { title, body, secTitle, date, tag, url } = r.item;
      const titleHl = highlight(title, r.matches, "title");
      const bodyHl  = highlight(body,  r.matches, "body");
      const domain = (() => { try { return url ? new URL(url).hostname.replace(/^www\./, "") : ""; } catch { return ""; } })();
      const faviconHtml = domain ? `<img class="card-favicon" src="https://www.google.com/s2/favicons?domain=${domain}&sz=16" width="14" height="14" loading="lazy" onerror="this.style.display='none'">` : "";
      const sourceHtml = url ? `<a class="card-source" href="${url}" target="_blank" rel="noopener">${faviconHtml}${domain || "查看原文"} ↗</a>` : "";
      const titleEl = url
        ? `<a class="card-title-text" href="${url}" target="_blank" rel="noopener">${titleHl}</a>`
        : `<span class="card-title-text">${titleHl}</span>`;
      return `<article class="card" ${url ? `data-url="${url}"` : ""} style="${url ? "cursor:pointer" : ""}">
        <div class="card-meta">${date} · ${secTitle}</div>
        <div class="card-title">${titleEl}${tagHtml(tag)}</div>
        <p class="card-body">${bodyHl}</p>
        <div class="card-footer">${sourceHtml}</div>
      </article>`;
    }).join("");
    main.innerHTML = `
      <div class="search-result-header">🔍 找到 <b>${results.length}</b> 条与 "<b>${query}</b>" 相关的内容</div>
      <div class="cards">${html}</div>`;
  }

  async function fetchManifest(): Promise<string[]> {
    const r = await fetch(`${BASE}manifest.json?t=${Date.now()}`);
    const m: Manifest = await r.json();
    return m.dates ?? [];
  }

  async function fetchDigest(date: string): Promise<Digest> {
    if (cache[date]) return cache[date];
    const r = await fetch(`${BASE}data/${date}.json?t=${Date.now()}`);
    if (!r.ok) throw new Error(`${r.status}`);
    const d: Digest = await r.json();
    cache[date] = d;
    buildFallbackIndex();
    return d;
  }

  function fmtDate(d: string): string {
    const [y, m, day] = d.split("-").map(Number);
    const dow = ["日","一","二","三","四","五","六"][new Date(y, m-1, day).getDay()];
    return `${m}月${day}日 周${dow}`;
  }

  function renderSidebar(selected: string) {
    const nav = document.getElementById("sidebar")!;
    const faveCount = getFaves().size;
    const faveBtn = `<button class="fave-entry-btn${selected === "__faves__" ? " active" : ""}" id="faveEntryBtn">⭐ 收藏${faveCount ? `<span class="fave-count">${faveCount}</span>` : ""}</button>`;
    const backToday = selected !== dates[0] && selected !== "__faves__"
      ? `<button class="back-today-btn" data-date="${dates[0]}">⬆ 今日</button>`
      : "";
    nav.innerHTML = '<span class="sidebar-label">历史</span>' + faveBtn + backToday +
      dates.slice(0, 30).map((d, i) => {
        const active = d === selected ? "active" : "";
        const label = i === 0 ? `今天` : `${d.slice(5).replace("-","月")}日`;
        const [y, mo, day] = d.split("-").map(Number);
        const dow = ["日","一","二","三","四","五","六"][new Date(y, mo-1, day).getDay()];
        const sub = `<span class="date-sub">周${dow}</span>`;
        return `<button class="date-btn ${active}" data-date="${d}">${label}${sub}</button>`;
      }).join("");
    nav.querySelectorAll(".date-btn,.back-today-btn").forEach(btn =>
      btn.addEventListener("click", () => {
        nav.querySelectorAll(".date-btn").forEach(b => b.classList.remove("loading"));
        (btn as HTMLElement).classList.add("loading");
        showDate((btn as HTMLElement).dataset.date!);
      })
    );
    document.getElementById("faveEntryBtn")?.addEventListener("click", () => {
      renderSidebar("__faves__");
      renderFavesPage();
      location.hash = "__faves__";
    });
  }

  function cardHtml(item: any, isJob: boolean, idx: number, defCollapsed = "card-body--collapsed"): string {
    const domain = (() => {
      try { return item.url ? new URL(item.url).hostname.replace(/^www\./, "") : ""; }
      catch { return ""; }
    })();
    const sourceHtml = domain
      ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener"><img class="card-favicon" src="https://www.google.com/s2/favicons?domain=${domain}&sz=16" width="14" height="14" loading="lazy" onerror="this.style.display='none'">${domain} ↗</a>`
      : item.url ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener">查看原文 ↗</a>` : "";
    const extraClass = isJob ? " card--job"
      : item.tag === "突发" ? " card--breaking"
      : item.tag === "重磅" ? " card--major" : "";
    const num = `<span class="card-num">${idx + 1}</span>`;
    const expandBtn = defCollapsed
      ? `<button class="card-expand">展开 ▾</button>`
      : ``;
    const faveHtml = item.url
      ? `<button class="fave-btn${isFaved(item.url) ? " faved" : ""}" data-url="${item.url}" title="${isFaved(item.url) ? "取消收藏" : "收藏"}">${isFaved(item.url) ? "★" : "☆"}</button>`
      : "";
    const urlAttr = item.url ? `data-url="${item.url}"` : "";
    const cursorStyle = item.url ? `style="cursor:pointer"` : "";
    return `<article class="card${extraClass}" ${urlAttr} ${cursorStyle}>
      <div class="card-title">${num}<span class="card-title-text">${item.title}</span>${tagHtml(item.tag)}</div>
      <div class="card-body-wrap${defCollapsed ? " card-body-wrap--collapsed" : ""}"><p class="card-body">${item.body}</p></div>
      <div class="card-footer">${sourceHtml}${expandBtn}${faveHtml}</div>
    </article>`;
  }

  // 今日看点英雄卡（第一条）
  function heroCardHtml(item: any): string {
    const domain = (() => { try { return item.url ? new URL(item.url).hostname.replace(/^www\./,"") : ""; } catch { return ""; } })();
    const src = domain ? `<a class="hero-source" href="${item.url}" target="_blank" rel="noopener"><img class="card-favicon" src="https://www.google.com/s2/favicons?domain=${domain}&sz=16" width="14" height="14" loading="lazy" onerror="this.style.display='none'">${domain} ↗</a>` : "";
    const faveHtml = item.url ? `<button class="fave-btn${isFaved(item.url) ? " faved" : ""}" data-url="${item.url}" title="${isFaved(item.url) ? "取消收藏" : "收藏"}">${isFaved(item.url) ? "★" : "☆"}</button>` : "";
    return `<article class="hero-card${item.tag === "突发" ? " card--breaking" : ""}" data-url="${item.url ?? ""}" ${item.url ? 'style="cursor:pointer"' : ""}>
      <div class="hero-tag-row">${tagHtml(item.tag)}<span class="hero-label">头条</span></div>
      <h2 class="hero-title">${item.title}</h2>
      <p class="hero-body">${item.body}</p>
      <div class="hero-footer">${src}${faveHtml}</div>
    </article>`;
  }

  function fmtBadge(d: Digest): string {
    const [y, m, day] = (d.date ?? "").split("-").map(Number);
    if (!y) return d.title ?? d.date ?? "";
    const dow = ["日","一","二","三","四","五","六"][new Date(y, m-1, day).getDay()];
    return `${m}月${day}日 · 周${dow}`;
  }

  function renderV2(d: Digest): string {
    const genTime = d.generated_at
      ? new Date(d.generated_at).toLocaleTimeString("zh-CN", { hour: "2-digit", minute: "2-digit", timeZone: "Asia/Shanghai" })
      : "";
    const sections = d.sections ?? [];
    const totalItems = sections.reduce((n, s) => n + (s.items?.length ?? 0), 0);

    const navHtml = sections
      .map(s => {
        const count = s.items?.length ?? 0;
        const badge = count ? `<span class="sec-nav-badge">${count}</span>` : "";
        return `<a class="sec-nav-btn" data-sec="${s.id}" href="#sec-${s.id}">${s.icon} ${s.title}${badge}</a>`;
      })
      .join("");

    const sectionsHtml = sections.map(s => {
      const isJob  = s.id === "jobs_hot";
      const isWide = WIDE_SECTIONS.has(s.id);
      const defCollapsed = isWide ? "" : "card-body--collapsed";
      const items = s.items ?? [];
      let cardsHtml: string;
      if (isWide && items.length > 0) {
        // 今日看点：第一条英雄卡 + 其余普通卡
        const hero = heroCardHtml(items[0]);
        const rest = items.slice(1).map((item, idx) => cardHtml(item, false, idx + 1, "")).join("");
        cardsHtml = `${hero}<div class="cards cards--grid">${rest}</div>`;
      } else {
        cardsHtml = `<div class="${isWide ? "cards cards--wide" : "cards cards--grid"}">${items.map((item, idx) => cardHtml(item, isJob, idx, defCollapsed)).join("")}</div>`;
      }
      return `<section class="section${isWide ? " section--wide" : ""}" id="sec-${s.id}">
        <div class="section-heading" style="--sec-color:${s.color}">
          <span class="section-icon">${s.icon}</span>
          <h2 class="section-title">${s.title}</h2>
          <button class="section-toggle" aria-label="折叠板块">▴</button>
        </div>
        ${cardsHtml}
      </section>`;
    }).join("");

    // 热词云
    const wordCloud = buildWordCloud(sections);

    return `
      <div class="digest-header">
        <div class="digest-top">
          <span class="digest-title">🗞️ 小新<b>日报</b></span>
          <span class="digest-badge">${fmtBadge(d)}</span>
        </div>
        ${d.summary ? `<div class="digest-summary"><p class="digest-summary-text">${d.summary}</p></div>` : ""}
        <div class="digest-stats">
          <span data-countup="${sections.length}" class="stats-num">${sections.length}</span> 板块
          <span class="stats-sep">·</span>
          <span data-countup="${totalItems}" class="stats-num">${totalItems}</span> 条资讯
          ${genTime ? `<span class="stats-sep">·</span><span>更新于 ${genTime}</span>` : ""}
        </div>
        ${wordCloud}
      </div>
      <nav class="sec-nav" id="secNav">${navHtml}</nav>
      ${sectionsHtml}`;
  }

  async function showDate(date: string) {
    renderSidebar(date);
    location.hash = date;
    const main = document.getElementById("main")!;
    main.classList.remove("main--fadein");
    main.innerHTML = `<div class="skeleton-wrap">
      <div class="skeleton skeleton-hero"></div>
      <div class="skeleton-nav">${Array(7).fill('<div class="skeleton skeleton-pill"></div>').join("")}</div>
      ${Array(3).fill(`<div class="skeleton-section">
        <div class="skeleton skeleton-heading"></div>
        ${Array(3).fill('<div class="skeleton skeleton-card"></div>').join("")}
      </div>`).join("")}
    </div>`;
    try {
      const d = await fetchDigest(date);
      main.innerHTML = renderV2(d);
      // 清掉 loading 状态
      document.querySelectorAll(".date-btn.loading").forEach(b => b.classList.remove("loading"));
      // countUp 动画
      main.querySelectorAll<HTMLElement>("[data-countup]").forEach(el => {
        const target = parseInt(el.dataset.countup ?? "0");
        if (target > 1) countUp(el, target);
      });
      // fade-in
      requestAnimationFrame(() => { main.classList.add("main--fadein"); });
      window.scrollTo({ top: 0, behavior: "instant" });
      initSectionObserver();
    } catch {
      main.innerHTML = '<div class="state-msg"><div class="icon">⚠️</div><p>加载失败，请稍后重试</p></div>';
    }
  }

  // ── sec-nav 滚动高亮 + 精确滚动 ──
  function initSectionObserver() {
    const setActive = (id: string) => {
      document.querySelectorAll<HTMLElement>(".sec-nav-btn").forEach(b =>
        b.classList.toggle("active", b.dataset.sec === id)
      );
    };

    // 精确滚动：计算 sticky header + sec-nav 高度后定位
    document.querySelectorAll<HTMLElement>(".sec-nav-btn").forEach(btn => {
      btn.addEventListener("click", e => {
        e.preventDefault();
        const secId = btn.dataset.sec!;
        const target = document.getElementById(`sec-${secId}`);
        if (!target) return;
        const header = document.querySelector(".site-header") as HTMLElement;
        const nav    = document.getElementById("secNav") as HTMLElement;
        const offset = (header?.offsetHeight ?? 53) + (nav?.offsetHeight ?? 45) + 12;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: "smooth" });
        setActive(secId);
      });
    });

    const obs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting)
          setActive(e.target.id.replace("sec-", ""));
      });
    }, { rootMargin: "-15% 0px -55% 0px" });

    document.querySelectorAll(".section").forEach(s => obs.observe(s));

    // 滚到底时强制激活最后一个板块
    window.addEventListener("scroll", () => {
      const atBottom = window.innerHeight + window.scrollY >= document.body.scrollHeight - 60;
      if (!atBottom) return;
      const sections = document.querySelectorAll<HTMLElement>(".section");
      const last = sections[sections.length - 1];
      if (last) setActive(last.id.replace("sec-", ""));
    }, { passive: true });
  }

  // ── 热词云 ──
  const STOP_WORDS = new Set("的了在是我有和就不都而及与这的到以在于并其为了之中由从等该对中国美国日本欧洲全球市场公司企业发展相关表示称已将通过".split(""));
  function buildWordCloud(sections: any[]): string {
    const freq: Record<string, number> = {};
    for (const s of sections) {
      for (const item of s.items ?? []) {
        const text = (item.title ?? "") + (item.body ?? "");
        // 提取2-5字中文词组
        const matches = text.match(/[\u4e00-\u9fa5]{2,5}/g) ?? [];
        for (const w of matches) {
          if ([...w].some(c => STOP_WORDS.has(c))) continue;
          freq[w] = (freq[w] ?? 0) + 1;
        }
      }
    }
    const sorted = Object.entries(freq)
      .filter(([, c]) => c >= 2)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 24);
    if (!sorted.length) return "";
    const max = sorted[0][1];
    const words = sorted.map(([w, c]) => {
      const size = Math.round(11 + (c / max) * 10);
      const opacity = 0.5 + (c / max) * 0.5;
      return `<button class="wc-word" style="font-size:${size}px;opacity:${opacity}" data-q="${w}">${w}</button>`;
    }).join("");
    return `<div class="word-cloud"><span class="wc-label">热词</span>${words}</div>`;
  }

  // ── 语音播报（Web Speech API） ──
  let ttsUtterance: SpeechSynthesisUtterance | null = null;
  let ttsPlaying = false;

  function buildTtsScript(digest: any): string {
    if (!digest) return "今日日报暂无内容。";
    const lines: string[] = [`${digest.date ?? "今日"}日报。`];
    if (digest.summary) lines.push(digest.summary);
    for (const sec of digest.sections ?? []) {
      lines.push(`${sec.title}板块。`);
      for (const item of (sec.items ?? []).slice(0, 3)) {
        lines.push(item.title + "。" + (item.body ?? "").slice(0, 60));
      }
    }
    return lines.join(" ");
  }

  function stopTts() {
    window.speechSynthesis.cancel();
    ttsPlaying = false;
    const btn = document.getElementById("ttsFab");
    if (btn) { btn.innerHTML = "<span>🔊</span>"; btn.title = "朗读今日日报"; btn.classList.remove("tts-playing"); }
  }

  function startTts(text: string) {
    stopTts();
    ttsUtterance = new SpeechSynthesisUtterance(text);
    ttsUtterance.lang = "zh-CN";
    ttsUtterance.rate = 1.05;
    ttsUtterance.pitch = 1;
    ttsUtterance.onend = () => stopTts();
    ttsUtterance.onerror = () => stopTts();
    window.speechSynthesis.speak(ttsUtterance);
    ttsPlaying = true;
    const btn = document.getElementById("ttsFab");
    if (btn) { btn.innerHTML = "<span>⏹</span>"; btn.title = "停止朗读"; btn.classList.add("tts-playing"); }
  }

  document.getElementById("ttsFab")?.addEventListener("click", () => {
    if (ttsPlaying) { stopTts(); return; }
    const date = location.hash.replace("#","") || dates[0];
    const digest = cache[date];
    if (!digest) { showToast("请先加载日报"); return; }
    startTts(buildTtsScript(digest));
    showToast("🔊 开始朗读今日日报...", 2500);
  });

  // ── AI 问答（Pollinations.ai 免费） ──
  let aiContext = "";
  let aiHistory: Array<{ role: string; content: string }> = [];

  function buildDigestContext(digest: any): string {
    if (!digest) return "";
    const lines = [`日期：${digest.date}`, `摘要：${digest.summary ?? "无"}`];
    for (const sec of digest.sections ?? []) {
      lines.push(`\n【${sec.title}】`);
      for (const item of sec.items ?? []) {
        lines.push(`- ${item.title}：${(item.body ?? "").slice(0, 120)}`);
      }
    }
    return lines.join("\n");
  }

  function appendAiMsg(role: "user" | "ai" | "loading", text: string): HTMLElement {
    const msgs = document.getElementById("aiMessages")!;
    const div = document.createElement("div");
    div.className = `ai-msg ai-msg--${role}`;
    if (role === "loading") {
      div.innerHTML = `<span class="ai-typing"><span></span><span></span><span></span></span>`;
    } else {
      div.textContent = text;
    }
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return div;
  }

  async function askAi(question: string) {
    if (!aiContext) {
      const date = location.hash.replace("#","") || dates[0];
      aiContext = buildDigestContext(cache[date] ?? null);
    }
    appendAiMsg("user", question);
    const loadEl = appendAiMsg("loading", "");
    const systemPrompt = `你是一个新闻助手。以下是今日日报全文，请基于这些内容回答用户问题，回答简洁清晰，中文，不超过200字。\n\n${aiContext}`;
    aiHistory.push({ role: "user", content: question });
    try {
      const messages = [
        { role: "system", content: systemPrompt },
        ...aiHistory.slice(-6)
      ];
      const res = await fetch("http://localhost:7799/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages, max_tokens: 400 }),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const answer = data.answer ?? data.error ?? "未能获取回答";
      loadEl.remove();
      const el = appendAiMsg("ai", answer);
      aiHistory.push({ role: "assistant", content: answer });
      // 打字机效果
      el.textContent = "";
      let i = 0;
      const timer = setInterval(() => {
        el.textContent += answer[i++];
        document.getElementById("aiMessages")!.scrollTop = 9999;
        if (i >= answer.length) clearInterval(timer);
      }, 18);
    } catch {
      loadEl.remove();
      appendAiMsg("ai", "连接 AI 代理失败，请确认 ai-proxy.py 正在运行（python3 ai-proxy.py）");
    }
  }

  // AI 面板开关
  const aiPanel = document.getElementById("aiPanel")!;
  document.getElementById("aiFab")?.addEventListener("click", () => {
    const open = aiPanel.classList.toggle("ai-panel--open");
    if (open) {
      // 重置上下文到当前日期
      aiContext = "";
      aiHistory = [];
      const date = location.hash.replace("#","") || dates[0];
      const sub = document.getElementById("aiPanelSub");
      if (sub) sub.textContent = `基于 ${date} 日报`;
      document.getElementById("aiInput")?.focus();
    }
  });
  document.getElementById("aiPanelClose")?.addEventListener("click", () => {
    aiPanel.classList.remove("ai-panel--open");
  });

  const aiInput = document.getElementById("aiInput") as HTMLInputElement;
  const aiSend = document.getElementById("aiSend")!;

  function submitAi() {
    const q = aiInput.value.trim();
    if (!q) return;
    aiInput.value = "";
    askAi(q);
  }
  aiSend.addEventListener("click", submitAi);
  aiInput.addEventListener("keydown", e => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); submitAi(); } });

  // ── countUp 动画 ──
  function countUp(el: HTMLElement, target: number, duration = 600) {
    const start = performance.now();
    const update = (now: number) => {
      const p = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - p, 3); // ease-out cubic
      el.textContent = String(Math.round(eased * target));
      if (p < 1) requestAnimationFrame(update);
    };
    requestAnimationFrame(update);
  }

  async function init() {
    // 显示构建时间
    const bt = document.getElementById("buildTime");
    if (bt) bt.textContent = `构建于 ${new Date().toLocaleString("zh-CN", { timeZone: "Asia/Shanghai", month:"numeric", day:"numeric", hour:"2-digit", minute:"2-digit" })}`;

    try {
      dates = await fetchManifest();
      if (!dates.length) {
        document.getElementById("sidebar")!.innerHTML = "";
        document.getElementById("main")!.innerHTML =
          '<div class="state-msg"><div class="icon">📭</div><p>还没有日报</p></div>';
        return;
      }
      const hash = location.hash.replace("#", "");
      // 并行加载搜索索引和首屏数据
      await Promise.all([
        loadSearchIndex(),
        showDate(hash && dates.includes(hash) ? hash : dates[0]),
      ]);
    } catch {
      document.getElementById("main")!.innerHTML =
        '<div class="state-msg"><div class="icon">⚠️</div><p>无法加载日报列表</p></div>';
    }
  }

  window.addEventListener("hashchange", () => {
    const d = location.hash.replace("#", "");
    if (d && dates.includes(d)) showDate(d);
  });

  // ── 主题切换（View Transitions 圆形扩散） ──
  const themeBtn = document.getElementById("themeToggle")!;

  function applyTheme(light: boolean, originX?: number, originY?: number) {
    const html = document.documentElement;
    const isLight = light;

    const doSwitch = () => {
      html.setAttribute("data-theme", isLight ? "light" : "dark");
      themeBtn.textContent = isLight ? "☀️" : "🌙";
      localStorage.setItem("theme", isLight ? "light" : "dark");
    };

    // View Transitions API 支持
    if (
      typeof document.startViewTransition === "function" &&
      originX !== undefined && originY !== undefined &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      // 计算从点击位置扩散到最远角的半径
      const maxR = Math.hypot(
        Math.max(originX, window.innerWidth - originX),
        Math.max(originY, window.innerHeight - originY)
      );
      document.documentElement.style.setProperty("--theme-x", `${originX}px`);
      document.documentElement.style.setProperty("--theme-y", `${originY}px`);
      document.documentElement.style.setProperty("--theme-r", `${maxR}px`);

      const transition = document.startViewTransition(doSwitch);
      transition.ready.then(() => {
        const clipFrom = `circle(0px at ${originX}px ${originY}px)`;
        const clipTo   = `circle(${maxR}px at ${originX}px ${originY}px)`;
        document.documentElement.animate(
          { clipPath: [clipFrom, clipTo] },
          { duration: 500, easing: "ease-in-out", pseudoElement: "::view-transition-new(root)" }
        );
      });
    } else {
      // 降级：直接切换
      html.style.transition = "background 0.3s, color 0.3s";
      doSwitch();
      setTimeout(() => { html.style.transition = ""; }, 350);
    }
  }

  applyTheme(document.documentElement.getAttribute("data-theme") === "light");
  themeBtn.addEventListener("click", (e) => {
    const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    applyTheme(document.documentElement.getAttribute("data-theme") !== "light", cx, cy);
  });

  // ── 回到顶部 ──
  const backTop = document.getElementById("backTop")!;
  window.addEventListener("scroll", () => {
    backTop.classList.toggle("visible", window.scrollY > 300);
  }, { passive: true });
  backTop.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));

  // ── 事件委托：展开/折叠卡片 + 折叠板块 + 收藏 + 热词云 ──
  document.getElementById("main")!.addEventListener("click", (e) => {
    const t = e.target as HTMLElement;

    // 收藏按钮
    const faveBtn = t.closest(".fave-btn") as HTMLElement | null;
    if (faveBtn) {
      e.stopPropagation();
      const url = faveBtn.dataset.url!;
      const now = toggleFave(url);
      faveBtn.textContent = now ? "★" : "☆";
      faveBtn.classList.toggle("faved", now);
      faveBtn.title = now ? "取消收藏" : "收藏";
      const faveEntry = document.getElementById("faveEntryBtn");
      if (faveEntry) {
        const fc = getFaves().size;
        const old = faveEntry.querySelector(".fave-count");
        if (fc) {
          if (old) old.textContent = String(fc);
          else faveEntry.insertAdjacentHTML("beforeend", `<span class="fave-count">${fc}</span>`);
        } else { old?.remove(); }
      }
      showToast(now ? "⭐ 已收藏" : "取消收藏");
      return;
    }

    // 热词云点击 → 触发搜索
    const wcWord = t.closest(".wc-word") as HTMLElement | null;
    if (wcWord) {
      const q = wcWord.dataset.q!;
      const sinput = document.getElementById("searchInput") as HTMLInputElement;
      sinput.value = q;
      sinput.dispatchEvent(new Event("input"));
      sinput.focus();
      return;
    }

    // 卡片整行跳转（data-url）
    const cardEl = t.closest(".card[data-url],.hero-card[data-url]") as HTMLElement | null;
    if (cardEl && !(t.closest("a,button"))) {
      window.open(cardEl.dataset.url, "_blank", "noopener");
      return;
    }

    // 展开卡片（平滑动画）
    const expandBtn = t.closest(".card-expand") as HTMLElement | null;
    if (expandBtn) {
      const wrap = expandBtn.closest(".card")!.querySelector(".card-body-wrap") as HTMLElement;
      const collapsed = wrap.classList.contains("card-body-wrap--collapsed");
      if (collapsed) {
        wrap.classList.remove("card-body-wrap--collapsed");
        wrap.style.maxHeight = wrap.scrollHeight + "px";
        setTimeout(() => { wrap.style.maxHeight = ""; }, 350);
      } else {
        wrap.style.maxHeight = wrap.scrollHeight + "px";
        requestAnimationFrame(() => {
          wrap.style.maxHeight = "3em";
          wrap.classList.add("card-body-wrap--collapsed");
        });
        setTimeout(() => { wrap.style.maxHeight = ""; }, 350);
      }
      expandBtn.textContent = collapsed ? "收起 ▴" : "展开 ▾";
      return;
    }

    // 折叠板块
    const toggleBtn = t.closest(".section-toggle") as HTMLElement | null;
    if (toggleBtn) {
      const section = toggleBtn.closest(".section")!;
      const cards = section.querySelector(".cards") as HTMLElement;
      const collapsed = cards.classList.toggle("cards--hidden");
      toggleBtn.textContent = collapsed ? "▾" : "▴";
      toggleBtn.classList.toggle("section-toggle--collapsed", collapsed);
    }
  });

  // ── 搜索 ──
  const searchInput = document.getElementById("searchInput") as HTMLInputElement;
  const searchClear = document.getElementById("searchClear") as HTMLElement;
  let searchTimer: ReturnType<typeof setTimeout>;

  function updateClearBtn() {
    searchClear.style.display = searchInput.value ? "flex" : "none";
  }

  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    updateClearBtn();
    const q = searchInput.value.trim();
    if (!q) {
      const current = location.hash.replace("#", "") || dates[0];
      if (current) showDate(current);
      return;
    }
    searchTimer = setTimeout(() => renderSearchResults(q), 300);
  });
  searchInput.addEventListener("keydown", e => {
    if (e.key === "Escape") {
      searchInput.value = "";
      updateClearBtn();
      searchInput.dispatchEvent(new Event("input"));
    }
  });
  searchClear.addEventListener("click", () => {
    searchInput.value = "";
    updateClearBtn();
    searchInput.dispatchEvent(new Event("input"));
    searchInput.focus();
  });

  // ── 搜索快捷键 `/` 或 ⌘K/Ctrl+K ──
  const searchKbd = document.getElementById("searchKbd");
  document.addEventListener("keydown", e => {
    const isSearchFocus = document.activeElement === searchInput;
    if ((e.key === "/" && !isSearchFocus) ||
        ((e.metaKey || e.ctrlKey) && e.key === "k")) {
      e.preventDefault();
      searchInput.focus();
      searchInput.select();
      if (searchKbd) searchKbd.style.display = "none";
    }
  });

  // ── 键盘导航 j/k/o/b ──
  let focusedCardIdx = -1;
  function getCards(): HTMLElement[] {
    return Array.from(document.querySelectorAll<HTMLElement>(".card, .hero-card"));
  }
  function focusCard(idx: number) {
    const cards = getCards();
    if (!cards.length) return;
    focusedCardIdx = Math.max(0, Math.min(idx, cards.length - 1));
    cards.forEach((c, i) => c.classList.toggle("card--focused", i === focusedCardIdx));
    cards[focusedCardIdx].scrollIntoView({ behavior: "smooth", block: "center" });
  }
  document.addEventListener("keydown", e => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if (tag === "INPUT" || tag === "TEXTAREA") return;
    const cards = getCards();
    if (e.key === "j") { e.preventDefault(); focusCard(focusedCardIdx < 0 ? 0 : focusedCardIdx + 1); }
    else if (e.key === "k") { e.preventDefault(); focusCard(focusedCardIdx <= 0 ? 0 : focusedCardIdx - 1); }
    else if (e.key === "o" && focusedCardIdx >= 0) {
      const url = cards[focusedCardIdx]?.dataset.url;
      if (url) window.open(url, "_blank", "noopener");
    } else if (e.key === "b" && focusedCardIdx >= 0) {
      const url = cards[focusedCardIdx]?.dataset.url;
      if (url) {
        const now = toggleFave(url);
        // 更新按钮状态
        const btn = cards[focusedCardIdx].querySelector<HTMLElement>(".fave-btn");
        if (btn) { btn.textContent = now ? "★" : "☆"; btn.classList.toggle("faved", now); }
        showToast(now ? "⭐ 已收藏" : "取消收藏");
      }
    } else if (e.key === "?") {
      showToast("⌨️ j/k 上下浏览 · o 打开原文 · b 收藏 · / 搜索", 5000);
    }
  });

  // ── 离线 Toast ──
  function showToast(msg: string, duration = 3500) {
    let t = document.getElementById("offlineToast") as HTMLElement;
    if (!t) {
      t = document.createElement("div");
      t.id = "offlineToast";
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.classList.add("toast--show");
    setTimeout(() => t.classList.remove("toast--show"), duration);
  }
  window.addEventListener("offline", () => showToast("📡 已离线，显示缓存内容"));
  window.addEventListener("online",  () => showToast("✅ 网络已恢复"));

  init();
</script>

<style is:global>
  /* ── Theme transition ── */
  *, *::before, *::after {
    transition: background-color 0.3s, border-color 0.3s, color 0.3s;
  }
  /* View Transitions：禁用默认淡入淡出，用圆形扩散 */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }
  ::view-transition-old(root) { z-index: 1; }
  ::view-transition-new(root) { z-index: 9999; }
  /* 但动画和变换不受影响 */
  .back-top, .main--fadein, .skeleton, .search-clear,
  .card-expand, .section-toggle, .sec-nav-btn, .date-btn {
    transition-property: background, border-color, color, opacity, transform, box-shadow;
  }
  .date-btn {
    display: flex; flex-direction: column;
    width: 100%; padding: 8px 10px 8px 12px;
    border-radius: 8px; background: none; border: none;
    color: var(--text2); font-size: 13px;
    text-align: left; cursor: pointer;
    transition: background 0.15s, color 0.15s; gap: 1px;
    position: relative;
  }
  .date-btn:hover { background: var(--bg3); color: var(--text); }
  .date-btn.active {
    background: rgba(231,76,60,0.12);
    color: var(--accent); font-weight: 700;
    border-left: 3px solid var(--accent);
    padding-left: 9px;
  }
  .date-btn.loading {
    opacity: 0.6;
    background: var(--bg3);
  }
  .date-btn.loading::after {
    content: '';
    display: inline-block; width: 8px; height: 8px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    border-top-color: transparent;
    animation: spin 0.6s linear infinite;
    margin-left: auto;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .date-sub { font-size: 10px; opacity: 0.6; font-weight: 400; }

  /* 返回今日 */
  .back-today-btn {
    display: block; width: calc(100% - 16px); margin: 0 8px 6px;
    padding: 6px 10px; border-radius: 8px;
    background: rgba(231,76,60,0.08); border: 1px dashed var(--accent);
    color: var(--accent); font-size: 12px; font-weight: 600;
    cursor: pointer; text-align: center;
  }
  .back-today-btn:hover { background: rgba(231,76,60,0.18); }
  @media (max-width: 680px) {
    .date-btn { flex-direction: row; align-items: center; width: auto; white-space: nowrap; padding: 6px 12px; gap: 4px; border-left: none !important; }
    .date-btn.active { background: var(--accent); color: #fff; padding-left: 12px; }
    .date-sub { display: none; }
  }

  /* ── Digest header ── */
  .digest-header { margin-bottom: 24px; }
  .digest-top { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; margin-bottom: 14px; }
  .digest-title { font-size: 18px; font-weight: 800; color: var(--accent); }
  .digest-title b { color: var(--heading); font-weight: 800; }
  .digest-badge {
    background: var(--accent); color: #fff;
    padding: 3px 12px; border-radius: 20px;
    font-size: 13px; font-weight: 600;
  }

  /* ── Summary Hero ── */
  .digest-summary {
    position: relative;
    background: var(--summary-bg);
    border: 1px solid var(--summary-border); border-radius: 14px;
    padding: 20px 22px 20px 26px; overflow: hidden;
    margin-bottom: 12px;
  }
  .digest-summary::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px; background: var(--accent);
    border-radius: 14px 0 0 14px;
  }
  .digest-summary::after {
    content: '今日速览'; position: absolute; top: 12px; right: 16px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
    color: var(--text3); text-transform: uppercase;
  }
  .digest-summary-text { font-size: 15px; font-weight: 500; color: var(--summary-text); line-height: 1.85; }

  /* ── Stats bar ── */
  .digest-stats {
    display: flex; align-items: center; gap: 8px; margin-top: 8px;
    font-size: 12px; color: var(--text3);
  }
  .stats-sep { opacity: 0.4; font-size: 14px; }
  .stats-num { font-weight: 700; color: var(--accent); font-variant-numeric: tabular-nums; }

  /* ── Section nav ── */
  .sec-nav {
    display: flex; gap: 6px; flex-wrap: wrap;
    margin-bottom: 24px; position: sticky;
    top: 53px; z-index: 100;
    background: var(--bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  @media (max-width: 680px) {
    .sec-nav {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: 8px 12px;
      gap: 6px;
    }
    .sec-nav::-webkit-scrollbar { display: none; }
  }
  .sec-nav-btn {
    padding: 4px 12px; border-radius: 20px;
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text2); font-size: 12px;
    text-decoration: none; transition: all 0.15s; white-space: nowrap;
    flex-shrink: 0; display: inline-flex; align-items: center; gap: 5px;
  }
  .sec-nav-btn:hover { background: var(--bg4); color: var(--text); border-color: var(--text3); text-decoration: none; }
  .sec-nav-btn.active {
    background: var(--accent); color: #fff;
    border-color: var(--accent); text-decoration: none;
  }
  .sec-nav-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 16px; height: 16px; border-radius: 8px;
    background: rgba(255,255,255,0.15); color: inherit;
    font-size: 10px; font-weight: 700; padding: 0 4px;
    line-height: 1;
  }
  .sec-nav-btn:not(.active) .sec-nav-badge {
    background: var(--bg4); color: var(--text3);
  }

  /* ── Section ── */
  .section { margin-bottom: 32px; scroll-margin-top: 110px; }
  .section-heading {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 12px; padding: 8px 12px 8px 14px;
    border-radius: 8px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-left: 4px solid var(--sec-color, #888);
    cursor: default;
    transition: background 0.15s, border-color 0.15s;
  }
  .section-heading:hover { background: var(--bg3); }
  .section-icon { font-size: 17px; line-height: 1; }
  .section-title { font-size: 15px; font-weight: 700; color: var(--heading); }
  .section-toggle {
    margin-left: auto;
    background: none; border: none; cursor: pointer;
    color: var(--text3); font-size: 12px; padding: 2px 6px;
    border-radius: 4px; transition: color 0.15s, background 0.15s; flex-shrink: 0;
  }
  .section-toggle:hover { background: var(--bg3); color: var(--text); }
  .section-toggle--collapsed { color: var(--accent) !important; }

  /* ── Main fade-in ── */
  .main { flex: 1; min-width: 0; padding: 24px 28px 60px; transition: opacity 0.25s ease; }
  @media (max-width: 680px) { .main { padding: 14px 12px 40px; } }
  .main--fadein { animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
  /* prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .main--fadein { animation: none; }
    .skeleton { animation: none; }
    .back-top { transition: opacity 0.1s; }
    *, *::before, *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }

  /* ── 今日看点 全宽 ── */
  .section--wide .cards--wide { display: flex; flex-direction: column; gap: 10px; }

  /* ── 双列卡片网格 ── */
  .cards--grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    align-items: start;
  }
  .cards--hidden { display: none !important; }

  @media (max-width: 900px) {
    .cards--grid { grid-template-columns: 1fr; }
  }

  /* ── Cards ── */
  /* .card 样式已移至文件末尾（含微放大效果） */
  /* placeholder */
  ._card_placeholder { display: none; }
  .card--job { border-left: 3px solid #f39c12; }
  .card--breaking { border-left: 3px solid #e74c3c; background: var(--breaking-bg); position: relative; overflow: hidden; }
  .card--breaking:hover { background: var(--breaking-hover); }
  .card--breaking::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: #e74c3c;
    animation: breakingPulse 2s ease-in-out infinite;
  }
  @keyframes breakingPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 4px #e74c3c; }
    50% { opacity: 0.4; box-shadow: none; }
  }
  .card--major { border-left: 3px solid #e67e22; background: var(--major-bg); }
  .card--major:hover { background: var(--major-hover); }
  .card-title {
    font-size: 14px; font-weight: 600; color: var(--heading);
    margin-bottom: 7px; display: flex; align-items: flex-start;
    flex-wrap: wrap; gap: 6px;
  }
  .card-num {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 18px; height: 18px; border-radius: 4px;
    background: var(--accent); color: #fff;
    font-size: 10px; font-weight: 700; flex-shrink: 0;
    margin-top: 2px; line-height: 1;
  }
  .card-title a { color: var(--heading); text-decoration: none; }
  .card-title a:hover { color: var(--link); }
  .card-title-text { flex: 1; min-width: 0; }  /* 防止长标题溢出挤压 tag */
  .card-body { font-size: 13px; color: var(--text); line-height: 1.75; flex: 1; }
  /* 平滑折叠包裹层 */
  .card-body-wrap {
    overflow: hidden;
    max-height: none;
    transition: max-height 0.35s ease;
  }
  .card-body-wrap--collapsed {
    max-height: 3em;
    -webkit-mask-image: linear-gradient(to bottom, #000 40%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 40%, transparent 100%);
  }
  /* 旧版搜索结果仍用旧方式 */
  .card-body--collapsed {
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .card-footer {
    display: flex; align-items: center;
    justify-content: space-between; margin-top: 8px; gap: 8px;
  }
  .card-source {
    font-size: 11px; color: var(--text3); text-decoration: none;
    opacity: 0.65; transition: opacity 0.15s;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;
    display: flex; align-items: center; gap: 4px;
  }
  .card-source:hover { opacity: 1; color: var(--link); }
  .card-favicon { border-radius: 2px; flex-shrink: 0; vertical-align: middle; }
  .card-expand {
    font-size: 11px; color: var(--text3);
    background: none; border: none; cursor: pointer;
    padding: 0; white-space: nowrap; flex-shrink: 0;
    opacity: 0.55; transition: opacity 0.15s;
  }
  .card-expand:hover { opacity: 1; color: var(--accent); }

  /* ── Tags ── */
  .tag {
    display: inline-block; padding: 1px 7px; border-radius: 4px;
    font-size: 11px; font-weight: 600; white-space: nowrap;
    flex-shrink: 0; margin-top: 2px;
  }
  .tag-breaking    { background: #7f1d1d; color: #fca5a5; }
  .tag-major       { background: #7c2d12; color: #fdba74; }
  .tag-analysis    { background: #1e3a5f; color: #93c5fd; }
  .tag-trend       { background: #14532d; color: #86efac; }
  .tag-watch       { background: #312e81; color: #c4b5fd; }
  .tag-opportunity { background: #064e3b; color: #6ee7b7; }
  .tag-alert       { background: #713f12; color: #fde68a; }
  .tag-knowledge   { background: #1f2937; color: #9ca3af; }
  .tag-default     { background: #2a2a2a; color: #aaa; }
  /* light override */
  [data-theme="light"] .tag-breaking    { background: #fee2e2; color: #991b1b; }
  [data-theme="light"] .tag-major       { background: #ffedd5; color: #9a3412; }
  [data-theme="light"] .tag-analysis    { background: #dbeafe; color: #1e40af; }
  [data-theme="light"] .tag-trend       { background: #dcfce7; color: #166534; }
  [data-theme="light"] .tag-watch       { background: #ede9fe; color: #4c1d95; }
  [data-theme="light"] .tag-opportunity { background: #d1fae5; color: #065f46; }
  [data-theme="light"] .tag-alert       { background: #fef3c7; color: #92400e; }
  [data-theme="light"] .tag-knowledge   { background: #f3f4f6; color: #374151; }
  [data-theme="light"] .tag-default     { background: #e5e7eb; color: #6b7280; }

  /* ── Skeleton ── */
  @keyframes shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position:  600px 0; }
  }
  .skeleton {
    border-radius: 8px;
    background: linear-gradient(90deg, var(--bg3) 25%, var(--bg4) 50%, var(--bg3) 75%);
    background-size: 1200px 100%;
    animation: shimmer 1.6s infinite linear;
    transition: none !important;  /* 防止全局 transition 干扰 shimmer */
  }
  .skeleton-wrap { padding: 0; }
  .skeleton-hero { height: 96px; margin-bottom: 20px; border-radius: 14px; }
  .skeleton-nav { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 24px; }
  .skeleton-pill { height: 28px; width: 80px; border-radius: 20px; }
  .skeleton-section { margin-bottom: 32px; }
  .skeleton-heading { height: 20px; width: 140px; margin-bottom: 12px; }
  .skeleton-card { height: 90px; margin-bottom: 10px; border-radius: var(--radius); }

  /* ── Back to top ── */
  .back-top {
    position: fixed; bottom: 28px; right: 24px;
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--accent); color: #fff;
    font-size: 18px; font-weight: 700; border: none; cursor: pointer;
    opacity: 0; transform: translateY(12px) scale(0.9);
    transition: opacity 0.25s, transform 0.25s;
    z-index: 300; display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px rgba(231,76,60,0.4); line-height: 1;
  }
  .back-top.visible { opacity: 1; transform: translateY(0) scale(1); }
  .back-top:hover { background: #c0392b; transform: translateY(-2px) scale(1.08); box-shadow: 0 6px 20px rgba(231,76,60,0.5); }

  /* ── Search ── */
  .search-result-header {
    font-size: 14px; color: var(--text2);
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .search-result-header b { color: var(--heading); }
  .card-meta { font-size: 11px; color: var(--text3); margin-bottom: 6px; }
  mark { background: rgba(231,76,60,0.2); color: var(--accent); border-radius: 2px; padding: 0 2px; }
  [data-theme="light"] mark { background: rgba(231,76,60,0.15); color: #b91c1c; }

  /* ── 今日看点卡片 hover ── */
  .section--wide .card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(231,76,60,0.1);
  }

  /* ── 离线 Toast ── */
  #offlineToast {
    position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: #1a1a1a; color: #fff;
    padding: 10px 20px; border-radius: 24px;
    font-size: 13px; font-weight: 500;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s, transform 0.3s;
    z-index: 9999; white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  #offlineToast.toast--show { opacity: 1; transform: translateX(-50%) translateY(0); }
  [data-theme="light"] #offlineToast { background: #333; }

  /* ── 英雄卡 ── */
  .hero-card {
    position: relative; overflow: hidden;
    background: var(--summary-bg);
    border: 1px solid var(--summary-border);
    border-radius: 14px;
    padding: 22px 24px 18px;
    margin-bottom: 12px;
    cursor: default;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .hero-card[data-url]:hover {
    border-color: var(--accent);
    box-shadow: 0 6px 28px rgba(231,76,60,0.15);
    transform: translateY(-2px);
  }
  .hero-tag-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .hero-label {
    font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
    color: var(--accent); text-transform: uppercase;
    background: rgba(231,76,60,0.1); padding: 2px 8px; border-radius: 4px;
  }
  .hero-title {
    font-size: 20px; font-weight: 800; color: var(--heading);
    line-height: 1.4; margin-bottom: 10px;
  }
  .hero-body { font-size: 14px; color: var(--text); line-height: 1.8; margin-bottom: 14px; }
  .hero-footer { display: flex; align-items: center; justify-content: space-between; }
  .hero-source {
    font-size: 12px; color: var(--text3); text-decoration: none;
    display: flex; align-items: center; gap: 4px; opacity: 0.7;
    transition: opacity 0.15s;
  }
  .hero-source:hover { opacity: 1; color: var(--link); }

  /* ── 收藏按钮 ── */
  .fave-btn {
    font-size: 14px; background: none; border: none; cursor: pointer;
    color: var(--text3); padding: 0 2px; flex-shrink: 0;
    opacity: 0.5; transition: opacity 0.15s, color 0.15s, transform 0.15s;
    line-height: 1;
  }
  .fave-btn:hover { opacity: 1; transform: scale(1.2); }
  .fave-btn.faved { color: #f39c12; opacity: 1; }
  .fave-entry-btn {
    display: flex; align-items: center; gap: 6px;
    width: 100%; padding: 8px 10px 8px 12px;
    border-radius: 8px; background: none; border: none;
    color: var(--text2); font-size: 13px; text-align: left;
    cursor: pointer; transition: background 0.15s, color 0.15s;
    margin-bottom: 4px;
  }
  .fave-entry-btn:hover { background: var(--bg3); color: var(--text); }
  .fave-entry-btn.active { background: rgba(243,156,18,0.12); color: #f39c12; font-weight: 700; }
  .fave-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 16px; height: 16px; border-radius: 8px;
    background: #f39c12; color: #fff;
    font-size: 10px; font-weight: 700; padding: 0 4px; line-height: 1;
    margin-left: auto;
  }
  .faves-header {
    font-size: 15px; font-weight: 700; color: var(--heading);
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  /* ── 热词云 ── */
  .word-cloud {
    display: flex; flex-wrap: wrap; align-items: center; gap: 6px 8px;
    margin-top: 10px; padding: 10px 14px;
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px;
  }
  .wc-label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
    color: var(--text3); text-transform: uppercase;
    margin-right: 4px; flex-shrink: 0;
  }
  .wc-word {
    background: none; border: none; cursor: pointer;
    color: var(--text2); font-family: var(--font);
    padding: 2px 4px; border-radius: 4px;
    transition: color 0.15s, background 0.15s, transform 0.15s;
    line-height: 1.4;
  }
  .wc-word:hover { color: var(--accent); background: rgba(231,76,60,0.08); transform: scale(1.1); }

  /* ── 卡片微放大 hover ── */
  .card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 14px 16px;
    transition: border-color 0.18s, background 0.18s, box-shadow 0.18s, transform 0.18s;
    display: flex; flex-direction: column;
  }
  .card:hover {
    border-color: var(--accent);
    background: var(--bg3);
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  /* ── 键盘导航 focused 卡片 ── */
  .card--focused {
    outline: 2px solid var(--accent) !important;
    outline-offset: 2px;
    box-shadow: 0 0 0 4px rgba(231,76,60,0.15) !important;
  }

  /* ── AI FAB 按钮组 ── */
  .ai-fab-wrap {
    position: fixed; bottom: 80px; right: 24px;
    display: flex; flex-direction: column; align-items: center; gap: 10px;
    z-index: 300;
  }
  .ai-fab, .tts-fab {
    width: 44px; height: 44px; border-radius: 50%;
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700;
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }
  .ai-fab {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
  }
  .ai-fab:hover { transform: translateY(-2px) scale(1.08); box-shadow: 0 6px 20px rgba(99,102,241,0.5); }
  .ai-fab-icon { font-size: 20px; line-height: 1; }
  .tts-fab {
    background: var(--bg3); color: var(--text2);
    border: 1px solid var(--border); font-size: 16px;
  }
  .tts-fab:hover { transform: translateY(-2px); background: var(--bg4); }
  .tts-fab.tts-playing { background: #e74c3c; color: #fff; border-color: #e74c3c; animation: ttsPulse 1.2s ease-in-out infinite; }
  @keyframes ttsPulse { 0%,100% { box-shadow: 0 0 0 0 rgba(231,76,60,0.4); } 50% { box-shadow: 0 0 0 8px rgba(231,76,60,0); } }

  /* ── AI 面板 ── */
  .ai-panel {
    position: fixed; bottom: 0; right: 24px;
    width: 360px; max-height: 520px;
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 16px 16px 0 0;
    box-shadow: 0 -4px 32px rgba(0,0,0,0.2);
    display: flex; flex-direction: column;
    z-index: 400;
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.34,1.56,0.64,1);
    overflow: hidden;
  }
  .ai-panel--open { transform: translateY(0); }
  @media (max-width: 680px) {
    .ai-panel { width: 100%; right: 0; border-radius: 16px 16px 0 0; }
    .ai-fab-wrap { right: 16px; bottom: 70px; }
  }
  .ai-panel-header {
    display: flex; align-items: center; gap: 8px;
