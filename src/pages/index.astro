---
import Base from "../layouts/Base.astro";
---

<Base title="小新日报">
  <!-- 阅读进度条 -->
  <div class="read-progress" id="readProgress"></div>

  <header class="site-header">
    <div class="header-row1">
      <div class="logo-block">
        <div class="logo">🗞️ 小新<span>日报</span></div>
        <div class="tagline">新闻 · 财经 · 科技 · 汽车 · 旅游 · 娱乐</div>
      </div>
      <div class="header-actions">
        <div class="search-wrap">
          <input
            id="searchInput"
            type="text"
            placeholder="搜索日报内容..."
            autocomplete="off"
            spellcheck="false"
          />
          <span class="search-icon">⌕</span>
          <kbd class="search-kbd" id="searchKbd">⌘K</kbd>
          <button id="searchClear" class="search-clear" style="display:none" aria-label="清空">✕</button>
        </div>
        <button class="theme-toggle" id="themeToggle" title="切换主题">🌙</button>
        <button class="share-btn" id="shareBtn" title="分享今日日报">🔗</button>
      </div>
    </div>
  </header>

  <div class="layout">
    <nav class="sidebar" id="sidebar">
      <span class="sidebar-label">历史</span>
    </nav>
    <div id="contentCol">
      <div id="sharedPanel"></div>
      <main class="main" id="main">
        <div class="state-msg"><div class="icon">⏳</div><p>加载中...</p></div>
      </main>
    </div>
  </div>

  <footer class="page-footer">
    <div class="footer-inner">
      <span>由小新 🔧 自动生成</span>
      <span class="footer-sep">·</span>
      <a href="https://github.com/Quantum505Void/daily-news-site" target="_blank" rel="noopener">GitHub</a>
      <span class="footer-sep">·</span>
      <span id="buildTime"></span>
    </div>
    <div class="footer-stats">
      <span class="footer-stat">👁 <span id="vercount_value_site_pv" class="footer-stat-val">--</span> 次浏览</span>
      <span class="footer-sep">·</span>
      <span class="footer-stat">👤 <span id="vercount_value_site_uv" class="footer-stat-val">--</span> 位访客</span>
    </div>
  </footer>

  <div class="ai-fab-wrap">
    <button class="back-top" id="backTop" aria-label="回到顶部" title="回到顶部">↑</button>
    <button class="ai-fab" id="aiFab" title="AI 问答">
      <span class="ai-fab-icon">✦</span>
    </button>
    <button class="tts-fab" id="ttsFab" title="朗读今日日报">
      <span>🔊</span>
    </button>
  </div>

  <!-- 移动端底部导航 -->
  <nav class="mobile-bottom-nav" id="mobileBottomNav">
    <button class="mob-nav-btn" data-sec="highlight">⚡<span>看点</span></button>
    <button class="mob-nav-btn" data-sec="tech">🤖<span>科技</span></button>
    <button class="mob-nav-btn" data-sec="economy">📈<span>财经</span></button>
    <button class="mob-nav-btn" data-sec="china">🇨🇳<span>国内</span></button>
    <button class="mob-nav-btn mob-nav-more" id="mobNavMore">☰<span>更多</span></button>
  </nav>
  <!-- 移动端更多板块弹出菜单 -->
  <div class="mob-more-sheet" id="mobMoreSheet">
    <div class="mob-more-grid">
      <button class="mob-more-btn" data-sec="world">🌍<span>国际</span></button>
      <button class="mob-more-btn" data-sec="military">🛡️<span>军事</span></button>
      <button class="mob-more-btn" data-sec="entertainment">🎬<span>娱乐</span></button>
      <button class="mob-more-btn" data-sec="sports">⚽<span>体育</span></button>
      <button class="mob-more-btn" data-sec="auto">🚗<span>汽车</span></button>
      <button class="mob-more-btn" data-sec="travel">✈️<span>旅游</span></button>
      <button class="mob-more-btn" data-sec="jobs_hot">💼<span>职场</span></button>
    </div>
  </div>

  <div class="ai-panel" id="aiPanel">
    <div class="ai-panel-header">
      <span class="ai-panel-title">✦ AI 问答</span>
      <span class="ai-panel-sub" id="aiPanelSub">GPT-5-mini · 基于今日日报</span>
      <button class="ai-panel-close" id="aiPanelClose">✕</button>
    </div>
    <div class="ai-messages" id="aiMessages">
      <div class="ai-msg ai-msg--hint" id="aiHintMsg">你好！我已读完今日日报，有什么想聊的？<br><span class="ai-hint-examples">试试：今天最重要的新闻是什么？科技领域有什么大事？</span></div>
      <div class="ai-suggestions" id="aiSuggestions"></div>
    </div>
    <div class="ai-input-row">
      <input class="ai-input" id="aiInput" placeholder="问我任何关于今日日报的问题..." autocomplete="off" />
      <button class="ai-send" id="aiSend">发送</button>
    </div>
  </div>
</Base>

<style>
  /* ── Header ── */
  .site-header {
    background: var(--header-bg);
    padding: 10px 24px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 200;
  }
  .header-row1 {
    display: flex; align-items: center; gap: 12px; width: 100%;
  }
  .header-actions {
    display: flex; align-items: center; gap: 8px; margin-left: auto;
  }
  /* ── logo ── */
  .logo { font-size: 22px; font-weight: 900; color: var(--accent); line-height: 1.1; letter-spacing: -0.5px; }
  .logo span { color: var(--heading); }
  .logo-block {
    display: flex; flex-direction: column; gap: 2px; flex-shrink: 0;
    position: relative;
  }
  .logo-block::before {
    content: '';
    position: absolute;
    top: -18px; left: -18px;
    width: 120px; height: 60px;
    background: radial-gradient(ellipse at 30% 50%, color-mix(in srgb, var(--accent) 18%, transparent) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }
  .logo, .tagline { position: relative; z-index: 1; }
  .tagline { font-size: 11px; color: var(--text2); letter-spacing: 0.5px; opacity: 0.7; }

  .search-wrap {
    position: relative;
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .search-clear {
    position: absolute; right: 8px; top: 50%;
    transform: translateY(-50%);
    background: none; border: none; cursor: pointer;
    color: var(--text3); font-size: 12px;
    display: flex; align-items: center; justify-content: center;
    width: 18px; height: 18px; border-radius: 50%;
    padding: 0; line-height: 1;
    transition: background 0.15s, color 0.15s;
  }
  .search-clear:hover { background: var(--bg4); color: var(--text); }
  .search-kbd {
    position: absolute; right: 10px; top: 50%;
    transform: translateY(-50%);
    font-size: 10px; color: var(--text3);
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: 4px; padding: 1px 5px;
    pointer-events: none; font-family: var(--font);
    transition: opacity 0.15s;
  }
  #searchInput:focus ~ .search-kbd { opacity: 0; }
  #searchInput {
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    border-radius: 20px;
    color: var(--text);
    font-size: 13px;
    font-family: var(--font);
    padding: 6px 14px 6px 32px;
    width: 200px;
    outline: none;
    transition: border-color 0.2s, width 0.3s, background 0.2s;
  }
  #searchInput:focus { border-color: var(--accent); background: var(--search-bg); width: 280px; }
  #searchInput::placeholder { color: var(--text3); }
  .search-icon {
    position: absolute; left: 10px; top: 50%;
    transform: translateY(-50%);
    color: var(--text3); font-size: 16px; pointer-events: none;
  }

  .theme-toggle, .share-btn {
    background: var(--search-bg);
    border: 1px solid var(--search-border);
    border-radius: 8px;
    padding: 5px 9px;
    font-size: 15px;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s;
    line-height: 1;
  }
  .theme-toggle:hover, .share-btn:hover { background: var(--bg3); }

  /* ── details 速览动画 ── */
  .digest-summary { overflow: hidden; }
  .digest-summary[open] .digest-summary-text {
    animation: slideDown 0.25s ease;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Layout ── */
  .layout {
    display: flex;
    max-width: 1280px;
    margin: 0 auto;
    min-height: calc(100vh - 53px - 52px);
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 148px;
    flex-shrink: 0;
    padding: 16px 8px;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 53px;
    height: calc(100vh - 53px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar-label {
    font-size: 10px; color: var(--text3);
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0 8px 8px;
  }

  /* ── Main ── */
  /* 已合并到 section-toggle 后的 .main 定义 */

  /* ── State msgs ── */
  :global(.state-msg) { text-align: center; padding: 80px 20px; color: var(--text2); }
  :global(.state-msg .icon) { font-size: 40px; margin-bottom: 12px; }

  /* ── Footer ── */
  .page-footer {
    text-align: center; padding: 24px 18px 20px;
    color: var(--text3); font-size: 12px;
    border-top: none;
    position: relative;
    display: flex; flex-direction: column; gap: 8px; align-items: center;
  }
  .page-footer::before {
    content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--border) 30%, var(--border) 70%, transparent);
  }
  .footer-inner { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center; }
  .footer-inner a { color: var(--text3); text-decoration: none; transition: color 0.15s; }
  .footer-inner a:hover { color: var(--accent); }
  .footer-sep { opacity: 0.3; }
  .footer-stats {
    display: flex; align-items: center; gap: 10px;
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 20px; padding: 4px 14px;
  }
  .footer-stat { display: flex; align-items: center; gap: 4px; font-size: 11px; }
  .footer-stat-val { font-weight: 700; color: var(--text2); transition: color 0.3s; }

  /* ── Mobile ── */
  @media (max-width: 680px) {
    .header-row1 { flex-wrap: wrap; }
    .header-actions { width: 100%; margin-left: 0; }
    .search-wrap { flex: 1; }
    #searchInput { width: 100%; }
    #searchInput:focus { width: 100%; }
    .tagline { font-size: 10px; }
    .sidebar {
      width: 100%; height: auto; position: static;
      flex-direction: row; flex-wrap: nowrap;
      overflow-x: auto; padding: 8px 12px;
      border-right: none; border-bottom: 1px solid var(--border); gap: 4px;
    }
    .sidebar-label { display: none; }
    .layout { flex-direction: column; }
  }
</style>

<script>
  import type { Digest, Manifest } from "../types";
  import Fuse from "fuse.js";

  const BASE = (import.meta.env.BASE_URL ?? "/").replace(/\/?$/, "/");
  const TAG_COLORS: Record<string, string> = {
    突发: "tag-breaking", 重磅: "tag-major", 分析: "tag-analysis",
    趋势: "tag-trend", 观察: "tag-watch", 机会: "tag-opportunity",
    提醒: "tag-alert", 知识库: "tag-knowledge",
  };

  const WIDE_SECTIONS = new Set(["highlight"]);

  // ── 收藏夹（localStorage） ──
  const FAVE_KEY = "xiaoxin_faves";
  const READ_KEY = "xiaoxin_read";
  function getFaves(): Set<string> {
    try { return new Set(JSON.parse(localStorage.getItem(FAVE_KEY) ?? "[]")); }
    catch { return new Set(); }
  }
  function saveFaves(s: Set<string>) {
    localStorage.setItem(FAVE_KEY, JSON.stringify([...s]));
  }
  function toggleFave(url: string): boolean {
    const s = getFaves(); const had = s.has(url);
    had ? s.delete(url) : s.add(url); saveFaves(s); return !had;
  }
  function isFaved(url: string): boolean { return getFaves().has(url); }

  // ── 已读（localStorage） ──
  function getReads(): Set<string> {
    try { return new Set(JSON.parse(localStorage.getItem(READ_KEY) ?? "[]")); }
    catch { return new Set(); }
  }
  function markRead(url: string) {
    const s = getReads(); s.add(url);
    // 最多保留 500 条，防止无限增长
    const arr = [...s].slice(-500);
    localStorage.setItem(READ_KEY, JSON.stringify(arr));
  }
  function isRead(url: string): boolean { return getReads().has(url); }

  // 渲染收藏页
  function renderFavesPage() {
    const faves = getFaves();
    const main = document.getElementById("main")!;
    if (!faves.size) {
      main.innerHTML = `<div class="state-msg"><div class="icon">⭐</div><p>还没有收藏</p><p style="font-size:12px;opacity:0.6;margin-top:6px">浏览日报时点击卡片右下角 ☆ 即可收藏</p></div>`;
      return;
    }
    // 从 cache 里找收藏的条目
    const items: Array<{ title: string; body: string; url: string; tag: string; secTitle: string; date: string }> = [];
    for (const [date, d] of Object.entries(cache)) {
      for (const sec of d.sections ?? []) {
        for (const item of sec.items ?? []) {
          if (item.url && faves.has(item.url)) {
            items.push({ ...item, secTitle: sec.title, date });
          }
        }
      }
    }
    if (!items.length) {
      main.innerHTML = `<div class="state-msg"><div class="icon">⭐</div><p>收藏的条目已不在缓存中，请先加载对应日期</p></div>`;
      return;
    }
    const html = items.map(item => {
      const domain = (() => { try { return item.url ? new URL(item.url).hostname.replace(/^www\./,"") : ""; } catch { return ""; } })();
      const src = domain ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener"><img class="card-favicon" src="https://icons.duckduckgo.com/ip3/${domain}.ico" width="14" height="14" loading="lazy" onerror="this.src='data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';this.style.display='none'">${domain} ↗</a>` : "";
      return `<article class="card" data-url="${item.url}" style="cursor:pointer">
        <div class="card-meta">${item.date} · ${item.secTitle}</div>
        <div class="card-title"><span class="card-title-text">${item.title}</span>${tagHtml(item.tag)}</div>
        <div class="card-body-wrap"><p class="card-body">${numHighlight(item.body ?? "")}</p></div>
        <div class="card-footer">${src}<button class="fave-btn faved" data-url="${item.url}" title="取消收藏">★</button></div>
      </article>`;
    }).join("");
    main.innerHTML = `<div class="faves-header">⭐ 已收藏 ${items.length} 条</div><div class="cards cards--grid">${html}</div>`;
    main.classList.add("main--fadein");
  }

  let dates: string[] = [];
  let cache: Record<string, Digest> = {};

  interface SearchDoc {
    date: string; secId: string; secTitle: string;
    title: string; body: string; tag: string; url: string;
  }
  let fuse: Fuse<SearchDoc> | null = null;

  async function loadSearchIndex() {
    try {
      const r = await fetch(`${BASE}search-index.json?t=${Date.now()}`);
      if (!r.ok) return;
      const docs: SearchDoc[] = await r.json();
      fuse = new Fuse(docs, {
        keys: [{ name: "title", weight: 2 }, { name: "body", weight: 1 }, { name: "secTitle", weight: 0.5 }],
        threshold: 0.4, includeMatches: true, minMatchCharLength: 2,
      });
    } catch { /* 降级：搜索只能搜已加载的 */ }
  }

  // 降级：从已加载数据建索引
  function buildFallbackIndex() {
    const docs: SearchDoc[] = [];
    for (const [date, d] of Object.entries(cache)) {
      for (const sec of d.sections ?? []) {
        for (const item of sec.items ?? []) {
          docs.push({ date, secId: sec.id, secTitle: sec.title,
            title: item.title, body: (item.body ?? "").slice(0, 100),
            tag: item.tag ?? "", url: item.url ?? "" });
        }
      }
    }
    if (!fuse && docs.length) {
      fuse = new Fuse(docs, {
        keys: [{ name: "title", weight: 2 }, { name: "body", weight: 1 }, { name: "secTitle", weight: 0.5 }],
        threshold: 0.4, includeMatches: true, minMatchCharLength: 2,
      });
    }
  }

  function numHighlight(text: string): string {
    return text.replace(/(\d+(?:\.\d+)?)\s*([%亿万元个条家项]|bp)/g, '<b class="num-hl">$1$2</b>');
  }

  function highlight(text: string, matches: readonly Fuse.FuseResultMatch[] | undefined, key: string): string {
    if (!matches) return text;
    const m = matches.find(m => m.key === key);
    if (!m?.indices?.length) return text;
    let result = "", last = 0;
    for (const [s, e] of m.indices) {
      result += text.slice(last, s) + `<mark>${text.slice(s, e + 1)}</mark>`;
      last = e + 1;
    }
    return result + text.slice(last);
  }

  function tagHtml(tag: string): string {
    if (!tag) return "";
    return `<span class="tag ${TAG_COLORS[tag] ?? "tag-default"}">${tag}</span>`;
  }

  function renderSearchResults(query: string) {
    if (!fuse || !query.trim()) return;
    const results = fuse.search(query, { limit: 20 });
    const main = document.getElementById("main")!;
    if (!results.length) {
      main.innerHTML = `<div class="state-msg"><div class="icon">🔍</div><p>没有找到 "${query}" 的相关内容</p></div>`;
      return;
    }
    const html = results.map(r => {
      const { title, body, secTitle, date, tag, url } = r.item;
      const titleHl = highlight(title, r.matches, "title");
      const bodyHl  = numHighlight(highlight(body,  r.matches, "body"));
      const domain = (() => { try { return url ? new URL(url).hostname.replace(/^www\./, "") : ""; } catch { return ""; } })();
      const faviconHtml = domain ? `<img class="card-favicon" src="https://icons.duckduckgo.com/ip3/${domain}.ico" width="14" height="14" loading="lazy" onerror="this.src='data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';this.style.display='none'">` : "";
      const sourceHtml = url ? `<a class="card-source" href="${url}" target="_blank" rel="noopener">${faviconHtml}${domain || "查看原文"} ↗</a>` : "";
      const titleEl = url
        ? `<a class="card-title-text" href="${url}" target="_blank" rel="noopener">${titleHl}</a>`
        : `<span class="card-title-text">${titleHl}</span>`;
      return `<article class="card" ${url ? `data-url="${url}"` : ""} style="${url ? "cursor:pointer" : ""}">
        <div class="card-meta">${date} · ${secTitle}</div>
        <div class="card-title">${titleEl}${tagHtml(tag)}</div>
        <p class="card-body">${bodyHl}</p>
        <div class="card-footer">${sourceHtml}</div>
      </article>`;
    }).join("");
    main.innerHTML = `
      <div class="search-result-header">🔍 找到 <b>${results.length}</b> 条与 "<b>${query}</b>" 相关的内容</div>
      <div class="cards">${html}</div>`;
  }

  async function fetchManifest(): Promise<string[]> {
    const r = await fetch(`${BASE}manifest.json?t=${Date.now()}`);
    const m: Manifest = await r.json();
    // Fix #10: 用 manifest.updated 显示真实构建时间
    const bt = document.getElementById("buildTime");
    if (bt && m.updated) {
      const d = new Date(m.updated);
      bt.textContent = `构建于 ${d.toLocaleString("zh-CN", { timeZone: "Asia/Shanghai", month:"numeric", day:"numeric", hour:"2-digit", minute:"2-digit" })}`;
    }
    return m.dates ?? [];
  }

  async function fetchDigest(date: string): Promise<Digest> {
    if (cache[date]) return cache[date];
    const r = await fetch(`${BASE}data/${date}.json?t=${Date.now()}`);
    if (!r.ok) throw new Error(`${r.status}`);
    const d: Digest = await r.json();
    cache[date] = d;
    buildFallbackIndex();
    return d;
  }

  function fmtDate(d: string): string {
    const [y, m, day] = d.split("-").map(Number);
    const dow = ["日","一","二","三","四","五","六"][new Date(y, m-1, day).getDay()];
    return `${m}月${day}日 周${dow}`;
  }

  function renderSidebar(selected: string) {
    const nav = document.getElementById("sidebar")!;
    const faveCount = getFaves().size;
    const faveBtn = `<button class="fave-entry-btn${selected === "__faves__" ? " active" : ""}" id="faveEntryBtn">⭐ 收藏${faveCount ? `<span class="fave-count">${faveCount}</span>` : ""}</button>`;
    const backToday = selected !== dates[0] && selected !== "__faves__"
      ? `<button class="back-today-btn" data-date="${dates[0]}">⬆ 今日</button>`
      : "";
    nav.innerHTML = '<span class="sidebar-label">历史</span>' + faveBtn + backToday +
      dates.slice(0, 30).map((d, i) => {
        const active = d === selected ? "active" : "";
        const label = i === 0 ? `今天` : `${d.slice(5).replace("-","月")}日`;
        const [y, mo, day] = d.split("-").map(Number);
        const dow = ["日","一","二","三","四","五","六"][new Date(y, mo-1, day).getDay()];
        const sub = `<span class="date-sub">周${dow}</span>`;
        return `<button class="date-btn ${active}" data-date="${d}">${label}${sub}</button>`;
      }).join("");
    nav.querySelectorAll(".date-btn,.back-today-btn").forEach(btn =>
      btn.addEventListener("click", () => {
        nav.querySelectorAll(".date-btn").forEach(b => b.classList.remove("loading"));
        (btn as HTMLElement).classList.add("loading");
        showDate((btn as HTMLElement).dataset.date!);
      })
    );
    document.getElementById("faveEntryBtn")?.addEventListener("click", () => {
      renderSidebar("__faves__");
      renderFavesPage();
      location.hash = "__faves__";
    });
  }

  function cardHtml(item: any, isJob: boolean, idx: number, defCollapsed = "card-body--collapsed", favedSet?: Set<string>): string {
    const domain = (() => {
      try { return item.url ? new URL(item.url).hostname.replace(/^www\./, "") : ""; }
      catch { return ""; }
    })();
    const sourceHtml = domain
      ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener"><img class="card-favicon" src="https://icons.duckduckgo.com/ip3/${domain}.ico" width="14" height="14" loading="lazy" onerror="this.src='data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';this.style.display='none'">${domain} ↗</a>`
      : item.url ? `<a class="card-source" href="${item.url}" target="_blank" rel="noopener">查看原文 ↗</a>` : "";
    const extraClass = isJob ? " card--job"
      : item.tag === "突发" ? " card--breaking"
      : item.tag === "重磅" ? " card--major" : "";
    const num = `<span class="card-num">${idx + 1}</span>`;
    const expandBtn = defCollapsed ? `<button class="card-expand">展开 ▾</button>` : ``;
    const faved = favedSet ? favedSet.has(item.url) : isFaved(item.url);
    const read  = item.url ? isRead(item.url) : false;
    const faveHtml = item.url
      ? `<button class="fave-btn${faved ? " faved" : ""}" data-url="${item.url}" title="${faved ? "取消收藏" : "收藏"}">${faved ? "★" : "☆"}</button>`
      : "";
    const urlAttr = item.url ? `data-url="${item.url}"` : "";
    const cursorStyle = item.url ? `style="cursor:pointer"` : "";
    const readClass = read ? " card--read" : "";
    return `<article class="card${extraClass}${readClass}" ${urlAttr} ${cursorStyle}>
      <div class="card-title">${num}<span class="card-title-text">${item.title}</span>${tagHtml(item.tag)}</div>
      <div class="card-body-wrap${defCollapsed ? " card-body-wrap--collapsed card-body-wrap--clickable" : ""}"><p class="card-body">${numHighlight(item.body ?? "")}</p></div>
      <div class="card-footer">${sourceHtml}${expandBtn}${faveHtml}</div>
    </article>`;
  }

  // 今日看点英雄卡（第一条）
  function heroCardHtml(item: any, favedSet?: Set<string>): string {
    const domain = (() => { try { return item.url ? new URL(item.url).hostname.replace(/^www\./,"") : ""; } catch { return ""; } })();
    const src = domain ? `<a class="hero-source" href="${item.url}" target="_blank" rel="noopener"><img class="card-favicon" src="https://icons.duckduckgo.com/ip3/${domain}.ico" width="14" height="14" loading="lazy" onerror="this.src='data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==';this.style.display='none'">${domain} ↗</a>` : "";
    const faved = favedSet ? favedSet.has(item.url) : isFaved(item.url);
    const faveHtml = item.url ? `<button class="fave-btn${faved ? " faved" : ""}" data-url="${item.url}" title="${faved ? "取消收藏" : "收藏"}">${faved ? "★" : "☆"}</button>` : "";
    return `<article class="hero-card${item.tag === "突发" ? " card--breaking" : ""}" data-url="${item.url ?? ""}" ${item.url ? 'style="cursor:pointer"' : ""}>
      <div class="hero-tag-row">${tagHtml(item.tag)}<span class="hero-label">头条</span></div>
      <h2 class="hero-title">${item.title}</h2>
      <p class="hero-body">${numHighlight(item.body ?? "")}</p>
      <div class="hero-footer">${src}${faveHtml}</div>
    </article>`;
  }

  function fmtBadge(d: Digest): string {
    const [y, m, day] = (d.date ?? "").split("-").map(Number);
    if (!y) return d.title ?? d.date ?? "";
    const dow = ["日","一","二","三","四","五","六"][new Date(y, m-1, day).getDay()];
    return `${m}月${day}日 · 周${dow}`;
  }

  function renderV2(d: Digest): string {
    const genTime = d.generated_at
      ? new Date(d.generated_at).toLocaleTimeString("zh-CN", { hour: "2-digit", minute: "2-digit", timeZone: "Asia/Shanghai" })
      : "";
    const sections = d.sections ?? [];
    const totalItems = sections.reduce((n, s) => n + (s.items?.length ?? 0), 0);
    const globalFavedSet = getFaves(); // 整个 renderV2 只读一次 localStorage

    const navHtml = sections
      .map(s => {
        const count = s.items?.length ?? 0;
        const badge = count ? `<span class="sec-nav-badge">${count}</span>` : "";
        return `<a class="sec-nav-btn" data-sec="${s.id}" href="#sec-${s.id}">${s.icon} ${s.title}${badge}</a>`;
      })
      .join("");

    const sectionsHtml = sections.map(s => {
      const isJob  = s.id === "jobs_hot";
      const isWide = WIDE_SECTIONS.has(s.id);
      const defCollapsed = isWide ? "" : "card-body--collapsed";
      const items = s.items ?? [];
      const favedSet = globalFavedSet;
      let cardsHtml: string;
      if (isWide && items.length > 0) {
        const hero = heroCardHtml(items[0], favedSet);
        const rest = items.slice(1).map((item, idx) => cardHtml(item, false, idx + 1, "", favedSet)).join("");
        cardsHtml = `${hero}<div class="cards cards--grid">${rest}</div>`;
      } else {
        cardsHtml = `<div class="${isWide ? "cards cards--wide" : "cards cards--grid"}">${items.map((item, idx) => cardHtml(item, isJob, idx, defCollapsed, favedSet)).join("")}</div>`;
      }
      return `<section class="section${isWide ? " section--wide" : ""}" id="sec-${s.id}">
        <div class="section-heading" style="--sec-color:${s.color}">
          <span class="section-icon">${s.icon}</span>
          <h2 class="section-title">${s.title}</h2>
          <button class="section-toggle" aria-label="折叠板块">▴</button>
        </div>
        ${cardsHtml}
      </section>`;
    }).join("");

        // 热词云：优先用 JSON 里服务端生成的 hot_words，降级到前端提取
    const wordCloud = d.hot_words?.length
      ? renderWordCloud(d.hot_words)
      : buildWordCloud(sections);

    return `
      <div class="digest-header">
        ${renderQuote(d)}
        <div class="digest-top">
          <div class="digest-title-row">
            <span class="digest-title">🗞️ 小新<b>日报</b></span>
            <span class="digest-badge">${fmtBadge(d)}</span>
          </div>
          <div class="digest-stats">
            <span class="stats-item"><span data-countup="${sections.length}" class="stats-num">${sections.length}</span><span class="stats-label">板块</span></span>
            <span class="stats-dot">·</span>
            <span class="stats-item"><span data-countup="${totalItems}" class="stats-num">${totalItems}</span><span class="stats-label">条资讯</span></span>
            ${genTime ? `<span class="stats-dot">·</span><span class="stats-update">📡 ${genTime}</span>` : ""}
          </div>
        </div>
        ${d.summary ? `<details class="digest-summary" id="digestSummary" open>
          <summary class="digest-summary-toggle">今日速览 <span class="digest-summary-arrow">▾</span></summary>
          <p class="digest-summary-text">${d.summary}</p>
        </details>` : ""}
        ${wordCloud}
        ${renderKeyNumbers(d)}
        ${renderAlmanac(d)}
      </div>
      <nav class="sec-nav" id="secNav">${navHtml}</nav>
      ${renderHistoryTimeline(d)}
      ${renderDailyQuestion(d)}
      ${sectionsHtml}`;
  }

  async function showDate(date: string) {
    renderSidebar(date);
    location.hash = date;
    hideDateTooltip(); // 切日期立刻隐藏 tooltip
    // 移动端底部导航：切日期时清空 active 状态
    document.querySelectorAll(".mob-nav-btn").forEach(b => b.classList.remove("active"));
    const main = document.getElementById("main")!;
    main.classList.remove("main--fadein");
    main.innerHTML = `<div class="skeleton-wrap">
      <div class="skeleton skeleton-hero"></div>
      <div class="skeleton-nav">${Array(7).fill('<div class="skeleton skeleton-pill"></div>').join("")}</div>
      ${Array(3).fill(`<div class="skeleton-section">
        <div class="skeleton skeleton-heading"></div>
        ${Array(3).fill('<div class="skeleton skeleton-card"></div>').join("")}
      </div>`).join("")}
    </div>`;
    try {
      const d = await fetchDigest(date);
      main.innerHTML = renderV2(d);
      focusedCardIdx = -1; // Fix #2: 切换日期重置键盘导航索引
      aiContext = "";      // Fix #4: 切换日期清空 AI context 缓存
      aiHistory = [];
      // 清掉 loading 状态
      document.querySelectorAll(".date-btn.loading").forEach(b => b.classList.remove("loading"));
      // countUp 动画
      main.querySelectorAll<HTMLElement>("[data-countup]").forEach(el => {
        const target = parseInt(el.dataset.countup ?? "0");
        if (target > 1) countUp(el, target);
      });
      // fade-in
      requestAnimationFrame(() => { main.classList.add("main--fadein"); });
      window.scrollTo({ top: 0, behavior: "instant" });
      initSectionObserver();
      restoreDQVotes();
      // 预备 AI 推荐问题（当 AI 面板打开时使用）
      if (d.hot_words?.length) {
        (window as any).__hotWords = d.hot_words;
      }
    } catch {
      main.innerHTML = '<div class="state-msg"><div class="icon">⚠️</div><p>加载失败，请稍后重试</p></div>';
    }
  }

  // ── sec-nav 滚动高亮 + 精确滚动 ──
  let _sectionObs: IntersectionObserver | null = null;

  // ── 阅读进度圆环 ──
  // ── 分享 ──
  function initShareBtn() {
    const btn = document.getElementById("shareBtn");
    if (!btn) return;
    btn.addEventListener("click", async () => {
      const url = location.href;
      const date = location.hash.replace("#", "") || "";
      const title = `小新日报 ${date}`;
      if (navigator.share) {
        try { await navigator.share({ title, url }); return; } catch {}
      }
      await navigator.clipboard.writeText(url);
      const orig = btn.textContent;
      btn.textContent = "✅";
      setTimeout(() => { btn.textContent = orig; }, 2000);
    });
  }

  function initSectionObserver() {
    const setActive = (id: string) => {
      document.querySelectorAll<HTMLElement>(".sec-nav-btn").forEach(b =>
        b.classList.toggle("active", b.dataset.sec === id)
      );
    };

    // 精确滚动：计算 sticky header + sec-nav 高度后定位
    document.querySelectorAll<HTMLElement>(".sec-nav-btn").forEach(btn => {
      btn.addEventListener("click", e => {
        e.preventDefault();
        const secId = btn.dataset.sec!;
        const target = document.getElementById(`sec-${secId}`);
        if (!target) return;
        const header = document.querySelector(".site-header") as HTMLElement;
        const nav    = document.getElementById("secNav") as HTMLElement;
        const offset = (header?.offsetHeight ?? 53) + (nav?.offsetHeight ?? 45) + 12;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: "smooth" });
        setActive(secId);
      });
    });

    // 断开旧 observer，重新 observe 新 DOM
    _sectionObs?.disconnect();
    _sectionObs = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting)
          setActive(e.target.id.replace("sec-", ""));
      });
    }, { rootMargin: "-15% 0px -55% 0px" });

    document.querySelectorAll(".section").forEach(s => _sectionObs!.observe(s));
  }

  // scroll 只注册一次（放全局，避免每次 showDate 累积）
  window.addEventListener("scroll", () => {
    const atBottom = window.innerHeight + window.scrollY >= document.body.scrollHeight - 60;
    if (!atBottom) return;
    const sections = document.querySelectorAll<HTMLElement>(".section");
    const last = sections[sections.length - 1];
    if (last) {
      document.querySelectorAll<HTMLElement>(".sec-nav-btn").forEach(b =>
        b.classList.toggle("active", b.dataset.sec === last.id.replace("sec-", ""))
      );
    }
  }, { passive: true });

  // ── 今日名言 ──
  function renderQuote(d: any): string {
    const q = d.quote;
    if (!q?.text || !q?.author) return "";
    const body = q.zh ? `<span class="quote-zh">${q.zh}</span>` : "";
    const copyText = q.zh
      ? `${q.zh} —— ${q.author}`
      : `${q.text} —— ${q.author}`;
    return `<blockquote class="daily-quote">
      <p class="quote-text">${q.text}</p>
      ${body}
      <div class="quote-footer">
        <cite class="quote-author">— ${q.author}</cite>
        <button class="quote-copy" data-text="${copyText.replace(/"/g,'&quot;')}" title="复制名言">📋 复制</button>
      </div>
    </blockquote>`;
  }

  // ── 今日时间轴 ──
  function renderDayTimeline(): string {
    const slots = [
      { h: 6,  label: "早晨", icon: "🌅" },
      { h: 9,  label: "上午", icon: "☀️" },
      { h: 12, label: "中午", icon: "🌞" },
      { h: 15, label: "下午", icon: "🌤️" },
      { h: 18, label: "傍晚", icon: "🌇" },
      { h: 21, label: "夜间", icon: "🌙" },
      { h: 24, label: "深夜", icon: "⭐" },
    ];
    const now = new Date();
    const passedMins = now.getHours() * 60 + now.getMinutes();
    const pct = Math.min(100, Math.round(passedMins / (24 * 60) * 100));
    const hhmm = `${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}`;
    const ticks = slots.map(s => {
      const tickPct = Math.round(s.h / 24 * 100);
      const passed = passedMins >= s.h * 60;
      return `<div class="tl-tick${passed ? " tl-tick--passed" : ""}" style="left:${tickPct}%">
        <span class="tl-tick-icon">${s.icon}</span>
        <span class="tl-tick-label">${s.label}</span>
      </div>`;
    }).join("");
    return `<div class="day-timeline" id="dayTimeline">
      <div class="tl-header">
        <span class="tl-title">今日时间轴</span>
        <span class="tl-time" id="tlTime">${hhmm}</span>
        <span class="tl-pct" id="tlPct">${pct}% 已过</span>
      </div>
      <div class="tl-track-wrap">
        <div class="tl-track">
          <div class="tl-fill" id="tlFill" style="width:${pct}%"></div>
          <div class="tl-cursor" id="tlCursor" style="left:${pct}%"></div>
        </div>
        <div class="tl-ticks">${ticks}</div>
      </div>
    </div>`;
  }

  // 时间轴每分钟更新
  // ── 共享模块：只初始化一次，切日期不重复渲染 ──
  function initSharedPanel() {
    const panel = document.getElementById("sharedPanel");
    if (!panel || panel.dataset.initialized) return;
    panel.dataset.initialized = "1";
    panel.innerHTML = renderMarketAlmanac({almanac: null}) + renderDayTimeline();
    injectMarketData();
    startTimelineTick();
  }

  function startTimelineTick() {
    function tick() {
      const now = new Date();
      const passedMins = now.getHours() * 60 + now.getMinutes();
      const pct = Math.min(100, Math.round(passedMins / (24 * 60) * 100));
      const hhmm = `${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}`;
      const fill = document.getElementById("tlFill");
      const cursor = document.getElementById("tlCursor");
      const time = document.getElementById("tlTime");
      const pctEl = document.getElementById("tlPct");
      if (fill) fill.style.width = `${pct}%`;
      if (cursor) cursor.style.left = `${pct}%`;
      if (time) time.textContent = hhmm;
      if (pctEl) pctEl.textContent = `${pct}% 已过`;
    }
    const msToNextMin = (60 - new Date().getSeconds()) * 1000;
    setTimeout(() => { tick(); setInterval(tick, 60000); }, msToNextMin);
  }

