    // 来源2：AllOrigins 代理 + Yahoo spark（无需自己的 Worker）
    const tryCorsProxy = async () => {
      const syms = SYMBOLS.map(s => s.sym).join(",");
      const target = `https://query2.finance.yahoo.com/v8/finance/spark?symbols=${encodeURIComponent(syms)}&range=1d&interval=1d`;
      const r = await fetch(
        `https://api.allorigins.win/raw?url=${encodeURIComponent(target)}`,
        { signal: AbortSignal.timeout(9000) }
      );
      if (!r.ok) throw new Error(`proxy ${r.status}`);
      return applyData(await r.json(), "Yahoo↗");
    };

    // 来源3：exchangerate.host 只获取汇率兜底展示
    const tryExchangeRate = async () => {
      const r = await fetch(
        "https://api.exchangerate.host/live?access_key=free&currencies=CNY&source=USD",
        { signal: AbortSignal.timeout(6000) }
