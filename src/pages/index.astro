  // 每日一问投票逻辑（事件委托，挂在 main 上）
  const WORKER = "https://xiaoxin-ai-proxy.moke521-wang.workers.dev";

  async function handleDailyQuestion(btn: HTMLElement) {
    const key = btn.dataset.key!;
    const idx = parseInt(btn.dataset.idx!);
    if (localStorage.getItem(key) !== null) return;
    localStorage.setItem(key, String(idx));

    const optsEl = btn.closest(".dq-options")!;
    const total = optsEl.querySelectorAll(".dq-opt").length;
    const card = btn.closest(".dq-card")!;

    // 立刻乐观显示本地结果（不等网络）
    const optimistic = Array(total).fill(0);
    optimistic[idx] = 1;
    showDQResult(card, idx, optimistic, key);

    // 后台静默发请求，拿到真实 tally 后更新
    try {
      const date = key.replace("dq_", "");
      const res = await fetch(`${WORKER}/vote?date=${date}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ idx, total }),
      });
      const data = await res.json();
      const tally: number[] = data.tally ?? optimistic;
      localStorage.setItem(`${key}_tally`, JSON.stringify(tally));
      showDQResult(card, idx, tally, key);
    } catch {
      localStorage.setItem(`${key}_tally`, JSON.stringify(optimistic));
    }
  }

  function showDQResult(card: Element, voted: number, tally: number[], key: string) {
    const optsEl = card.querySelector<HTMLElement>(".dq-options");
    const resultEl = card.querySelector<HTMLElement>(".dq-result");
    if (!optsEl || !resultEl) return;
    const total = tally.reduce((a, b) => a + b, 0) || 1;
    const bars = tally.map((v, i) => {
      const pct = Math.round(v / total * 100);
      const letter = String.fromCharCode(65 + i);
      const optBtn = optsEl.querySelectorAll(".dq-opt")[i];
      const label = optBtn?.textContent?.replace(/^[A-D]\. /, "") ?? "";
      const isVoted = i === voted;
      return `<div class="dq-bar-row${isVoted ? " dq-bar-row--voted" : ""}">
        <span class="dq-bar-label">${letter}. ${label}</span>
        <div class="dq-bar-track"><div class="dq-bar-fill" style="width:${pct}%"></div></div>
        <span class="dq-bar-pct">${pct}%</span>
      </div>`;
    }).join("");
    optsEl.style.display = "none";
    resultEl.style.display = "";
    resultEl.innerHTML = `<div class="dq-total">${total} 人参与</div>` + bars;
  }

  // 初始化时恢复已投票状态（已投过则从服务端拉最新结果）
  function restoreDQVotes() {
    document.querySelectorAll<HTMLElement>(".dq-options").forEach(optsEl => {
      const btn0 = optsEl.querySelector<HTMLElement>(".dq-opt");
      if (!btn0) return;
      const key = btn0.dataset.key!;
      const voted = localStorage.getItem(key);
      if (voted === null) return;
      const date = key.replace("dq_", "");
      const card = optsEl.closest(".dq-card")!;
      // 先用本地 tally 快速渲染，再从服务端刷新
      const localTally: number[] = JSON.parse(localStorage.getItem(`${key}_tally`) ?? "[]");
      if (localTally.length) showDQResult(card, parseInt(voted), localTally, key);
      // 后台刷新服务端最新数据
      fetch(`${WORKER}/vote?date=${date}`)
        .then(r => r.json())
        .then(data => {
          if (data.tally?.length) {
            localStorage.setItem(`${key}_tally`, JSON.stringify(data.tally));
            showDQResult(card, parseInt(voted), data.tally, key);
          }
        }).catch(() => {});
    });
  }

  // 直接渲染服务端已计算好的热词
  function renderWordCloud(hotWords: Array<{word: string, count: number}>): string {
    if (!hotWords?.length) return "";
    const max = hotWords[0].count;
    const words = hotWords.map(({ word, count }) => {
      const ratio = count / max;
      const size = Math.round(12 + ratio * 14);
      const opacity = 0.55 + ratio * 0.45;
      const weight = ratio > 0.6 ? 700 : ratio > 0.3 ? 600 : 400;
      return `<button class="wc-word" style="font-size:${size}px;opacity:${opacity};font-weight:${weight}" data-q="${word}">${word}</button>`;
    }).join("");
    return `<div class="word-cloud"><span class="wc-label">热词</span>${words}</div>`;
  }

  // ── 热词云（前端降级版，当 JSON 无 hot_words 时使用） ──
  const STOP_WORDS = new Set([
    "中国","美国","日本","欧洲","全球","市场","公司","企业","发展","相关",
    "表示","表明","称已","将通","通过","计划","目前","方面","进行","工作",
    "推出","实现","提出","提供","建设","加强","支持","合作","增长","增加",
    "下降","同比","环比","亿元","万元","百分","以上","以下","今年","去年",
    "国内","国际","政府","部门","官员","记者","报道","消息","据悉","此前",
    "目前","已经","可以","需要","没有","这个","那么","什么","如何","为何",
  ]);
  function buildWordCloud(sections: any[]): string {
    const freq: Record<string, number> = {};
    for (const s of sections) {
      for (const item of s.items ?? []) {
        const text = (item.title ?? "") + (item.body ?? "");
        const matches = text.match(/[\u4e00-\u9fa5]{2,6}/g) ?? [];
        for (const w of matches) {
          if (STOP_WORDS.has(w)) continue;
          // 过滤纯方位/数量词
          if (/^[一二三四五六七八九十百千万亿第]+$/.test(w)) continue;
          freq[w] = (freq[w] ?? 0) + 1;
        }
      }
    }
    const sorted = Object.entries(freq)
      .filter(([, c]) => c >= 2)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 24);
    if (!sorted.length) return "";
    const max = sorted[0][1];
    const words = sorted.map(([w, c]) => {
      const ratio = c / max;
      const size = Math.round(12 + ratio * 14);
      const opacity = 0.55 + ratio * 0.45;
      const weight = ratio > 0.6 ? 700 : ratio > 0.3 ? 600 : 400;
      return `<button class="wc-word" style="font-size:${size}px;opacity:${opacity};font-weight:${weight}" data-q="${w}">${w}</button>`;
    }).join("");
    return `<div class="word-cloud"><span class="wc-label">热词</span>${words}</div>`;
  }

  // ── 语音播报（Web Speech API） ──
  let ttsPlaying = false;
  let ttsQueue: string[] = [];
  let ttsKeepAliveTimer: ReturnType<typeof setInterval> | null = null;

  function buildTtsScript(digest: any): string {
    if (!digest) return "今日日报暂无内容。";
    const lines: string[] = [`${digest.date ?? "今日"}日报。`];
    if (digest.summary) lines.push(digest.summary);
    for (const sec of digest.sections ?? []) {
      lines.push(`${sec.title}板块。`);
      for (const item of (sec.items ?? []).slice(0, 3)) {
        lines.push(item.title + "。" + (item.body ?? "").slice(0, 60));
      }
    }
    return lines.join(" ");
  }

  // 把文本按句子切成 ≤100 字的小块，避免 Chrome 长文本静默停止 bug
  function chunkText(text: string): string[] {
    const sentences = text.split(/(?<=[。！？；.!?;])\s*/);
    const chunks: string[] = [];
    let cur = "";
    for (const s of sentences) {
      if (!s.trim()) continue;
      if (cur.length + s.length > 100) {
        if (cur) chunks.push(cur.trim());
        cur = s;
      } else {
        cur += s;
      }
    }
    if (cur.trim()) chunks.push(cur.trim());
    return chunks;
  }

  function speakNext() {
    if (!ttsPlaying || !ttsQueue.length) {
      stopTts();
      return;
    }
    const chunk = ttsQueue.shift()!;
    const utt = new SpeechSynthesisUtterance(chunk);
    utt.lang = "zh-CN";
    utt.rate = 1.05;
    utt.pitch = 1;
    utt.onend = () => {
      if (ttsPlaying) speakNext();
    };
    utt.onerror = (e) => {
      // interrupted = 手动停止，不报错；其他错误跳过继续
      if ((e as SpeechSynthesisErrorEvent).error !== "interrupted") speakNext();
    };
    window.speechSynthesis.cancel(); // 清掉上一句残留
    window.speechSynthesis.speak(utt);
  }

  function stopTts() {
    ttsPlaying = false;
    ttsQueue = [];
    if (ttsKeepAliveTimer) { clearInterval(ttsKeepAliveTimer); ttsKeepAliveTimer = null; }
    window.speechSynthesis.cancel();
    const btn = document.getElementById("ttsFab");
    if (btn) { btn.innerHTML = "<span>🔊</span>"; btn.title = "朗读今日日报"; btn.classList.remove("tts-playing"); }
  }

  function startTts(text: string) {
    stopTts();
    ttsQueue = chunkText(text);
    if (!ttsQueue.length) return;
    ttsPlaying = true;
    // Chrome 额外保险：每 10s 检查是否卡住，卡住则强制播下一段
    ttsKeepAliveTimer = setInterval(() => {
      if (!ttsPlaying) return;
      if (!window.speechSynthesis.speaking && ttsQueue.length) speakNext();
    }, 10000);
    speakNext();
    const btn = document.getElementById("ttsFab");
    if (btn) { btn.innerHTML = "<span>⏹</span>"; btn.title = "停止朗读"; btn.classList.add("tts-playing"); }
  }

  document.getElementById("ttsFab")?.addEventListener("click", () => {
    if (ttsPlaying) { stopTts(); return; }
    const date = location.hash.replace("#","") || dates[0];
    const digest = cache[date];
    if (!digest) { showToast("请先加载日报"); return; }
    startTts(buildTtsScript(digest));
    showToast("🔊 开始朗读今日日报...", 2500);
  });

  // ── AI 问答（Pollinations.ai 免费） ──
  let aiContext = "";
  let aiHistory: Array<{ role: string; content: string }> = [];

  function buildDigestContext(digest: any): string {
    if (!digest) return "";
    const lines = [`日期：${digest.date}`, `摘要：${digest.summary ?? "无"}`];
    for (const sec of digest.sections ?? []) {
      lines.push(`\n【${sec.title}】`);
      for (const item of sec.items ?? []) {
        lines.push(`- ${item.title}：${(item.body ?? "").slice(0, 120)}`);
      }
    }
    return lines.join("\n");
  }

  function appendAiMsg(role: "user" | "ai" | "loading", text: string): HTMLElement {
    const msgs = document.getElementById("aiMessages")!;
    const div = document.createElement("div");
    div.className = `ai-msg ai-msg--${role}`;
    if (role === "loading") {
      div.innerHTML = `<span class="ai-typing"><span></span><span></span><span></span></span>`;
    } else {
      div.textContent = text;
    }
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return div;
  }

  async function askAi(question: string) {
    if (!aiContext) {
      const date = location.hash.replace("#","") || dates[0];
      aiContext = buildDigestContext(cache[date] ?? null);
    }
    appendAiMsg("user", question);
    const loadEl = appendAiMsg("loading", "");
    const systemPrompt = `你是一个新闻助手。以下是今日日报全文，请基于这些内容回答用户问题，回答简洁清晰，中文，不超过200字。\n\n${aiContext}`;
    aiHistory.push({ role: "user", content: question });
    try {
      const messages = [
        { role: "system", content: systemPrompt },
        ...aiHistory.slice(-6)
      ];
      const res = await fetch("https://xiaoxin-ai-proxy.moke521-wang.workers.dev/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages, max_tokens: 400 }),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      const answer = data.answer ?? data.error ?? "未能获取回答";
      loadEl.remove();
      const el = appendAiMsg("ai", answer);
      aiHistory.push({ role: "assistant", content: answer });
      // 打字机效果
      el.textContent = "";
      let i = 0;
      const timer = setInterval(() => {
        el.textContent += answer[i++];
        document.getElementById("aiMessages")!.scrollTop = 9999;
        if (i >= answer.length) clearInterval(timer);
      }, 18);
    } catch {
      loadEl.remove();
      appendAiMsg("ai", "AI 请求失败，请稍后重试");
    }
  }

