---
import Base from "../layouts/Base.astro";
---

<Base title="小新日报">
  <header class="site-header">
    <div class="logo-block">
      <div class="logo">🗞️ 小新<span>日报</span></div>
      <div class="tagline">每日新闻 · 科技 · 军事 · 财经 · 娱乐</div>
    </div>
    <div class="header-date" id="headerDate"></div>
    <div class="search-wrap">
      <input
        id="searchInput"
        type="search"
        placeholder="搜索日报内容..."
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-icon">⌕</span>
    </div>
  </header>

  <div class="layout">
    <nav class="sidebar" id="sidebar">
      <span class="sidebar-label">历史</span>
    </nav>
    <main class="main" id="main">
      <div class="state-msg"><div class="icon">⏳</div><p>加载中...</p></div>
    </main>
  </div>

  <footer class="page-footer">
    由小新 🔧 自动生成 ·
    <a href="https://github.com/Quantum505Void/daily-news-site" target="_blank" rel="noopener">
      GitHub
    </a>
  </footer>

  <button class="back-top" id="backTop" aria-label="回到顶部" title="回到顶部">↑</button>
</Base>

<style>
  /* ── Header ── */
  .site-header {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
    padding: 10px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 200;
    flex-wrap: wrap;
  }
  .logo { font-size: 22px; font-weight: 900; color: var(--accent); line-height: 1.1; letter-spacing: -0.5px; }
  .logo span { color: #fff; }
  .logo-block { display: flex; flex-direction: column; gap: 2px; flex-shrink: 0; }
  .tagline { font-size: 11px; color: var(--text2); letter-spacing: 0.5px; opacity: 0.8; }
  .header-date {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    background: rgba(231,76,60,0.12);
    border: 1px solid rgba(231,76,60,0.25);
    border-radius: 8px;
    padding: 3px 10px;
    flex-shrink: 0;
    letter-spacing: 0.5px;
  }

  .search-wrap {
    position: relative;
    margin-left: auto;
    flex-shrink: 0;
  }
  #searchInput {
    background: rgba(255,255,255,0.07);
    border: 1px solid #2a3a5e;
    border-radius: 20px;
    color: var(--text);
    font-size: 13px;
    font-family: var(--font);
    padding: 6px 14px 6px 32px;
    width: 200px;
    outline: none;
    transition: border-color 0.2s, width 0.3s, background 0.2s;
  }
  #searchInput:focus {
    border-color: #4a6ea8;
    background: rgba(255,255,255,0.1);
    width: 280px;
  }
  #searchInput::placeholder { color: var(--text3); }
  .search-icon {
    position: absolute;
    left: 10px; top: 50%;
    transform: translateY(-50%);
    color: var(--text3);
    font-size: 16px;
    pointer-events: none;
  }

  @media (max-width: 680px) {
    .search-wrap { margin-left: 0; width: 100%; }
    #searchInput { width: 100%; }
    #searchInput:focus { width: 100%; }
    .tagline { display: block; font-size: 10px; }
  }

  /* ── Layout ── */
  .layout {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 53px - 52px);
  }

  /* ── Sidebar ── */
  .sidebar {
    width: 140px;
    flex-shrink: 0;
    padding: 16px 8px;
    border-right: 1px solid var(--border);
    position: sticky;
    top: 53px;
    height: calc(100vh - 53px);
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .sidebar-label {
    font-size: 10px;
    color: var(--text3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0 8px 8px;
  }

  /* ── Main ── */
  .main { flex: 1; min-width: 0; padding: 28px 32px 60px; }

  /* ── State msgs ── */
  :global(.state-msg) {
    text-align: center;
    padding: 80px 20px;
    color: var(--text2);
  }
  :global(.state-msg .icon) { font-size: 40px; margin-bottom: 12px; }

  /* ── Footer ── */
  .page-footer {
    text-align: center;
    padding: 18px;
    color: var(--text3);
    font-size: 12px;
    border-top: 1px solid var(--border);
  }

  /* ── Mobile ── */
  @media (max-width: 680px) {
    .sidebar {
      width: 100%;
      height: auto;
      position: static;
      flex-direction: row;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding: 8px 12px;
      border-right: none;
      border-bottom: 1px solid var(--border);
      gap: 4px;
    }
    .sidebar-label { display: none; }
    .layout { flex-direction: column; }
    .main { padding: 16px 14px 40px; }
  }
</style>

<script>
  import type { Digest, Manifest } from "../types";
  import Fuse from "fuse.js";

  // ── 常量 ──
  const BASE = (import.meta.env.BASE_URL ?? "/").replace(/\/?$/, "/");
  const TAG_COLORS: Record<string, string> = {
    突发: "tag-breaking", 重磅: "tag-major", 分析: "tag-analysis",
    趋势: "tag-trend", 观察: "tag-watch", 机会: "tag-opportunity",
    提醒: "tag-alert", 知识库: "tag-knowledge",
  };

  let dates: string[] = [];
  let cache: Record<string, Digest> = {};

  // ── Search index ──
  interface SearchDoc {
    date: string;
    sectionTitle: string;
    title: string;
    body: string;
    tag: string;
    url: string;
  }
  let searchDocs: SearchDoc[] = [];
  let fuse: Fuse<SearchDoc> | null = null;

  function buildSearchIndex() {
    searchDocs = [];
    for (const [date, d] of Object.entries(cache)) {
      for (const sec of d.sections ?? []) {
        for (const item of sec.items ?? []) {
          searchDocs.push({
            date,
            sectionTitle: sec.title,
            title: item.title,
            body: item.body,
            tag: item.tag ?? "",
            url: item.url ?? "",
          });
        }
      }
    }
    fuse = new Fuse(searchDocs, {
      keys: [
        { name: "title", weight: 2 },
        { name: "body", weight: 1 },
        { name: "sectionTitle", weight: 0.5 },
      ],
      threshold: 0.4,
      includeMatches: true,
      minMatchCharLength: 2,
    });
  }

  function highlight(text: string, matches: readonly Fuse.FuseResultMatch[] | undefined, key: string): string {
    if (!matches) return text;
    const m = matches.find(m => m.key === key);
    if (!m?.indices?.length) return text;
    let result = "";
    let last = 0;
    for (const [start, end] of m.indices) {
      result += text.slice(last, start);
      result += `<mark>${text.slice(start, end + 1)}</mark>`;
      last = end + 1;
    }
    result += text.slice(last);
    return result;
  }

  function renderSearchResults(query: string) {
    if (!fuse || !query.trim()) return;
    const results = fuse.search(query, { limit: 20 });
    const main = document.getElementById("main")!;

    if (!results.length) {
      main.innerHTML = `<div class="state-msg"><div class="icon">🔍</div><p>没有找到 "${query}" 的相关内容</p></div>`;
      return;
    }

    const html = results.map(r => {
      const { title, body, sectionTitle, date, tag, url } = r.item;
      const titleHl = highlight(title, r.matches, "title");
      const bodyHl  = highlight(body,  r.matches, "body");
      const tagHl   = tag ? `<span class="tag ${TAG_COLORS[tag] ?? "tag-default"}">${tag}</span>` : "";
      const titleEl = url
        ? `<a href="${url}" target="_blank" rel="noopener">${titleHl}</a>`
        : `<span>${titleHl}</span>`;
      return `<article class="card">
        <div class="card-meta">${date} · ${sectionTitle}</div>
        <div class="card-title">${titleEl}${tagHl}</div>
        <p class="card-body">${bodyHl}</p>
      </article>`;
    }).join("");

    main.innerHTML = `
      <div class="search-result-header">
        🔍 找到 <b>${results.length}</b> 条与 "<b>${query}</b>" 相关的内容
      </div>
      <div class="cards">${html}</div>`;
  }

  // ── 数据加载 ──
  async function fetchManifest(): Promise<string[]> {
    const r = await fetch(`${BASE}manifest.json?t=${Date.now()}`);
    const m: Manifest = await r.json();
    return m.dates ?? [];
  }

  async function fetchDigest(date: string): Promise<Digest> {
    if (cache[date]) return cache[date];
    const r = await fetch(`${BASE}data/小新日报-${date}.json?t=${Date.now()}`);
    if (!r.ok) throw new Error(`${r.status}`);
    const d: Digest = await r.json();
    cache[date] = d;
    buildSearchIndex();
    return d;
  }

  // ── 渲染 ──
  function fmtDate(d: string): string {
    const [, m, day] = d.split("-");
    return `${parseInt(m)}月${parseInt(day)}日`;
  }

  function renderSidebar(selected: string) {
    const nav = document.getElementById("sidebar")!;
    nav.innerHTML =
      '<span class="sidebar-label">历史</span>' +
      dates
        .slice(0, 30)
        .map((d, i) => {
          const active = d === selected ? "active" : "";
          const label = i === 0 ? `今天 ${fmtDate(d)}` : fmtDate(d);
          return `<button class="date-btn ${active}" data-date="${d}">${label}</button>`;
        })
        .join("");

    nav.querySelectorAll(".date-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const date = (btn as HTMLElement).dataset.date!;
        showDate(date);
      });
    });
  }

  function tagHtml(tag: string): string {
    if (!tag) return "";
    const cls = TAG_COLORS[tag] ?? "tag-default";
    return `<span class="tag ${cls}">${tag}</span>`;
  }

  function renderV2(d: Digest): string {
    const genTime = d.generated_at
      ? new Date(d.generated_at).toLocaleTimeString("zh-CN", {
          hour: "2-digit",
          minute: "2-digit",
          timeZone: "Asia/Shanghai",
        })
      : "";

    const sections = d.sections ?? [];
    const navHtml = sections
      .map((s) => `<a class="sec-nav-btn" href="#sec-${s.id}">${s.icon} ${s.title}</a>`)
      .join("");

    const sectionsHtml = sections
      .map((s) => {
        const isJob = s.id === "jobs_hot";
        const cards = (s.items ?? [])
          .map((item) => {
            const titleEl = item.url
              ? `<a href="${item.url}" target="_blank" rel="noopener">${item.title}</a>`
              : `<span>${item.title}</span>`;
            const extraClass = isJob ? " card--job"
              : item.tag === "突发" ? " card--breaking"
              : item.tag === "重磅" ? " card--major"
              : "";
            return `<article class="card${extraClass}">
              <div class="card-title">${titleEl}${tagHtml(item.tag)}</div>
              <p class="card-body">${item.body}</p>
            </article>`;
          })
          .join("");

        return `<section class="section" id="sec-${s.id}">
          <div class="section-heading">
            <span class="section-icon">${s.icon}</span>
            <h2 class="section-title">${s.title}</h2>
            <div class="section-bar" style="background:${s.color}"></div>
          </div>
          <div class="cards">${cards}</div>
        </section>`;
      })
      .join("");

    return `
      <div class="digest-header">
        <div class="digest-top">
          <span class="digest-title">🗞️ 小新<b>日报</b></span>
          <span class="digest-badge">${d.title ?? d.date}</span>
          ${genTime ? `<span class="digest-time">生成于 ${genTime}</span>` : ""}
        </div>
        ${d.summary ? `<div class="digest-summary"><p class="digest-summary-text">${d.summary}</p></div>` : ""}
      </div>
      <nav class="sec-nav">${navHtml}</nav>
      ${sectionsHtml}
    `;
  }

  async function showDate(date: string) {
    renderSidebar(date);
    location.hash = date;
    const el = document.getElementById("headerDate");
    if (el) el.textContent = fmtDate(date);
    const main = document.getElementById("main")!;
    main.innerHTML = `
      <div class="skeleton-wrap">
        <div class="skeleton skeleton-hero"></div>
        <div class="skeleton-nav">
          ${Array(6).fill('<div class="skeleton skeleton-pill"></div>').join("")}
        </div>
        ${Array(3).fill(`
          <div class="skeleton-section">
            <div class="skeleton skeleton-heading"></div>
            ${Array(3).fill('<div class="skeleton skeleton-card"></div>').join("")}
          </div>
        `).join("")}
      </div>`;

    try {
      const d = await fetchDigest(date);
      main.innerHTML = renderV2(d);
      window.scrollTo({ top: 0, behavior: "instant" });
    } catch {
      main.innerHTML = '<div class="state-msg"><div class="icon">⚠️</div><p>加载失败，请稍后重试</p></div>';
    }
  }

  async function init() {
    try {
      dates = await fetchManifest();
      if (!dates.length) {
        document.getElementById("sidebar")!.innerHTML = "";
        document.getElementById("main")!.innerHTML =
          '<div class="state-msg"><div class="icon">📭</div><p>还没有日报</p></div>';
        return;
      }
      const hash = location.hash.replace("#", "");
      const selected = hash && dates.includes(hash) ? hash : dates[0];
      await showDate(selected);
    } catch {
      document.getElementById("main")!.innerHTML =
        '<div class="state-msg"><div class="icon">⚠️</div><p>无法加载日报列表</p></div>';
    }
  }

  window.addEventListener("hashchange", () => {
    const d = location.hash.replace("#", "");
    if (d && dates.includes(d)) showDate(d);
  });

  // ── Back to top ──
  const backTop = document.getElementById("backTop")!;
  window.addEventListener("scroll", () => {
    backTop.classList.toggle("visible", window.scrollY > 300);
  }, { passive: true });
  backTop.addEventListener("click", () => {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  // ── Search ──
  const searchInput = document.getElementById("searchInput") as HTMLInputElement;
  let searchTimer: ReturnType<typeof setTimeout>;
  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    const q = searchInput.value.trim();
    if (!q) {
      // 还原当前日期视图
      const current = location.hash.replace("#", "") || dates[0];
      if (current) showDate(current);
      return;
    }
    searchTimer = setTimeout(() => renderSearchResults(q), 300);
  });
  searchInput.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      searchInput.value = "";
      searchInput.dispatchEvent(new Event("input"));
    }
  });

  init();
</script>

<style is:global>
  /* ── Sidebar buttons (injected by JS) ── */
  .date-btn {
    display: block;
    width: 100%;
    padding: 8px 10px;
    border-radius: 8px;
    background: none;
    border: none;
    color: var(--text2);
    font-size: 13px;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .date-btn:hover { background: var(--bg3); color: var(--text); }
  .date-btn.active { background: var(--accent); color: #fff; font-weight: 600; }

  @media (max-width: 680px) {
    .date-btn { width: auto; white-space: nowrap; padding: 6px 12px; }
  }

  /* ── Digest header ── */
  .digest-header {
    margin-bottom: 28px;
  }
  .digest-top {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 16px;
  }
  .digest-title { font-size: 18px; font-weight: 800; color: var(--accent); }
  .digest-title b { color: #fff; font-weight: 800; }
  .digest-badge {
    background: var(--accent);
    color: #fff;
    padding: 3px 12px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
  }
  .digest-time { font-size: 12px; color: var(--text3); margin-left: auto; }

  /* ── Summary Hero ── */
  .digest-summary {
    position: relative;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #1a1a2e 100%);
    border: 1px solid #2a3a5e;
    border-radius: 14px;
    padding: 22px 24px 22px 28px;
    overflow: hidden;
  }
  .digest-summary::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: linear-gradient(to bottom, #e74c3c, #c0392b);
    border-radius: 14px 0 0 14px;
  }
  .digest-summary::after {
    content: '今日速览';
    position: absolute;
    top: 14px; right: 18px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #3a5080;
    text-transform: uppercase;
  }
  .digest-summary-text {
    font-size: 16px;
    font-weight: 500;
    color: #c8d8f0;
    line-height: 1.85;
  }

  /* ── Section nav ── */
  .sec-nav {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }
  .sec-nav-btn {
    padding: 4px 12px;
    border-radius: 20px;
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text2);
    font-size: 12px;
    text-decoration: none;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .sec-nav-btn:hover {
    background: var(--bg4);
    color: var(--text);
    border-color: #444;
    text-decoration: none;
  }

  /* ── Section ── */
  .section { margin-bottom: 36px; scroll-margin-top: 70px; }
  .section-heading {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }
  .section-icon { font-size: 18px; line-height: 1; }
  .section-title { font-size: 17px; font-weight: 700; color: var(--heading); }
  .section-bar { height: 3px; width: 32px; border-radius: 2px; margin-left: auto; flex-shrink: 0; }
  .cards { display: flex; flex-direction: column; gap: 10px; }

  /* ── Cards ── */
  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 16px;
    transition: border-color 0.18s, background 0.18s;
  }
  .card:hover { border-color: #3a3a3a; background: var(--bg3); }
  .card--job { border-left: 3px solid #f39c12; }
  /* 突发：红色左边框 + 深红背景 */
  .card--breaking {
    border-left: 3px solid #e74c3c;
    background: #1a0f0f;
  }
  .card--breaking:hover { background: #201313; }
  /* 重磅：橙色左边框 + 深橙背景 */
  .card--major {
    border-left: 3px solid #e67e22;
    background: #1a1208;
  }
  .card--major:hover { background: #201608; }
  .card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--heading);
    margin-bottom: 7px;
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 8px;
  }
  .card-title a { color: var(--heading); text-decoration: none; }
  .card-title a:hover { color: var(--link); }
  .card-body { font-size: 14px; color: var(--text); line-height: 1.75; }

  /* ── Tags ── */
  .tag {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .tag-breaking    { background: #7f1d1d; color: #fca5a5; }
  .tag-major       { background: #7c2d12; color: #fdba74; }
  .tag-analysis    { background: #1e3a5f; color: #93c5fd; }
  .tag-trend       { background: #14532d; color: #86efac; }
  .tag-watch       { background: #312e81; color: #c4b5fd; }
  .tag-opportunity { background: #064e3b; color: #6ee7b7; }
  .tag-alert       { background: #713f12; color: #fde68a; }
  .tag-knowledge   { background: #1f2937; color: #9ca3af; }
  .tag-default     { background: #2a2a2a; color: #aaa; }

  /* ── Skeleton screen ── */
  @keyframes shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position:  600px 0; }
  }
  .skeleton {
    border-radius: 8px;
    background: linear-gradient(90deg, #1e1e1e 25%, #2a2a2a 50%, #1e1e1e 75%);
    background-size: 1200px 100%;
    animation: shimmer 1.6s infinite linear;
  }
  .skeleton-wrap { padding: 0; }
  .skeleton-hero { height: 100px; margin-bottom: 20px; border-radius: 14px; }
  .skeleton-nav {
    display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 28px;
  }
  .skeleton-pill { height: 28px; width: 80px; border-radius: 20px; }
  .skeleton-section { margin-bottom: 36px; }
  .skeleton-heading { height: 20px; width: 140px; margin-bottom: 14px; }
  .skeleton-card { height: 80px; margin-bottom: 10px; border-radius: var(--radius); }

  /* ── Back to top ── */
  .back-top {
    position: fixed;
    bottom: 28px;
    right: 24px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    font-size: 18px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.25s, transform 0.25s;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(231, 76, 60, 0.4);
    line-height: 1;
  }
  .back-top.visible { opacity: 1; transform: translateY(0); }
  .back-top:hover { background: #c0392b; }

  /* ── Search results ── */
  .search-result-header {
    font-size: 14px;
    color: var(--text2);
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .search-result-header b { color: var(--heading); }
