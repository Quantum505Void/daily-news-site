  // ── 主题切换（View Transitions 圆形扩散） ──
  const themeBtn = document.getElementById("themeToggle")!;

  function applyTheme(light: boolean, originX?: number, originY?: number) {
    const html = document.documentElement;
    const isLight = light;

    const doSwitch = () => {
      html.setAttribute("data-theme", isLight ? "light" : "dark");
      themeBtn.textContent = isLight ? "☀️" : "🌙";
      localStorage.setItem("theme", isLight ? "light" : "dark");
    };

    // View Transitions API 支持
    if (
      typeof document.startViewTransition === "function" &&
      originX !== undefined && originY !== undefined &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      // 计算从点击位置扩散到最远角的半径
      const maxR = Math.hypot(
        Math.max(originX, window.innerWidth - originX),
        Math.max(originY, window.innerHeight - originY)
      );
      document.documentElement.style.setProperty("--theme-x", `${originX}px`);
      document.documentElement.style.setProperty("--theme-y", `${originY}px`);
      document.documentElement.style.setProperty("--theme-r", `${maxR}px`);

      const transition = document.startViewTransition(doSwitch);
      transition.ready.then(() => {
        const clipFrom = `circle(0px at ${originX}px ${originY}px)`;
        const clipTo   = `circle(${maxR}px at ${originX}px ${originY}px)`;
        document.documentElement.animate(
          { clipPath: [clipFrom, clipTo] },
          { duration: 500, easing: "ease-in-out", pseudoElement: "::view-transition-new(root)" }
        );
      });
    } else {
      // 降级：直接切换
      html.style.transition = "background 0.3s, color 0.3s";
      doSwitch();
      setTimeout(() => { html.style.transition = ""; }, 350);
    }
  }

  applyTheme(document.documentElement.getAttribute("data-theme") === "light");
  themeBtn.addEventListener("click", (e) => {
    const rect = (e.currentTarget as HTMLElement).getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    applyTheme(document.documentElement.getAttribute("data-theme") !== "light", cx, cy);
  });

  // ── 回到顶部（进度条 scroll 已包含 visible 逻辑，此处只注册点击） ──
  const backTop = document.getElementById("backTop")!;
  backTop.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));

  // ── 事件委托：展开/折叠卡片 + 折叠板块 + 收藏 + 热词云 ──
  document.getElementById("main")!.addEventListener("click", (e) => {
    const t = e.target as HTMLElement;

    // 名言复制
    const copyBtn = t.closest(".quote-copy") as HTMLElement | null;
    if (copyBtn) {
      const text = copyBtn.dataset.text ?? "";
      navigator.clipboard.writeText(text).then(() => {
        const orig = copyBtn.textContent;
        copyBtn.textContent = "✅ 已复制";
        setTimeout(() => { copyBtn.textContent = orig; }, 2000);
      });
      return;
    }

    // 每日一问投票
    const dqBtn = t.closest(".dq-opt") as HTMLElement | null;
    if (dqBtn) { void handleDailyQuestion(dqBtn); return; }

    // 收藏按钮
    const faveBtn = t.closest(".fave-btn") as HTMLElement | null;
    if (faveBtn) {
      e.stopPropagation();
      const url = faveBtn.dataset.url!;
      const now = toggleFave(url);
      faveBtn.textContent = now ? "★" : "☆";
      faveBtn.classList.toggle("faved", now);
      faveBtn.title = now ? "取消收藏" : "收藏";
      const faveEntry = document.getElementById("faveEntryBtn");
      if (faveEntry) {
        const fc = getFaves().size;
        const old = faveEntry.querySelector(".fave-count");
        if (fc) {
          if (old) old.textContent = String(fc);
          else faveEntry.insertAdjacentHTML("beforeend", `<span class="fave-count">${fc}</span>`);
        } else { old?.remove(); }
      }
      showToast(now ? "⭐ 已收藏" : "取消收藏");
      return;
    }

    // 热词云点击 → 高亮卡片（优先），降级触发搜索
    const wcWord = t.closest(".wc-word") as HTMLElement | null;
    if (wcWord) {
      const q = wcWord.dataset.q!;
      // 找所有卡片里含该词的
      const allCards = Array.from(document.querySelectorAll<HTMLElement>(".card, .hero-card"));
      // 先精确匹配，失败则用前缀降级（中文关键词前2字往往足够定位）
      let matched = allCards.filter(c => (c.textContent ?? "").includes(q));
      if (!matched.length && q.length >= 3) {
        const sub = q.slice(0, Math.max(2, Math.ceil(q.length / 2)));
        matched = allCards.filter(c => (c.textContent ?? "").includes(sub));
      }
      if (matched.length) {
        // 清除旧高亮
        allCards.forEach(c => c.classList.remove("card--highlighted"));
        matched.forEach(c => c.classList.add("card--highlighted"));
        // 滚动到第一个
        matched[0].scrollIntoView({ behavior: "smooth", block: "center" });
        // 3秒后清除高亮
        setTimeout(() => matched.forEach(c => c.classList.remove("card--highlighted")), 3000);
      } else {
        // 没匹配到则降级搜索
        const sinput = document.getElementById("searchInput") as HTMLInputElement;
        sinput.value = q;
        sinput.dispatchEvent(new Event("input"));
        sinput.focus();
      }
      return;
    }

    // 卡片整行跳转（data-url）
    const cardEl = t.closest(".card[data-url],.hero-card[data-url]") as HTMLElement | null;
    if (cardEl && !(t.closest("a,button"))) {
      const url = cardEl.dataset.url!;
      markRead(url);
      cardEl.classList.add("card--read");
      window.open(url, "_blank", "noopener");
      return;
    }

    // 展开卡片（平滑动画）
    const expandBtn = t.closest(".card-expand") as HTMLElement | null;
    // 点折叠区域本身也能展开
    const bodyWrap = t.closest(".card-body-wrap--clickable") as HTMLElement | null;
    const expandTrigger = expandBtn ?? (bodyWrap?.classList.contains("card-body-wrap--collapsed") ? bodyWrap : null);
    if (expandTrigger) {
      const wrap = (expandBtn
        ? expandBtn.closest(".card")!.querySelector(".card-body-wrap")
        : bodyWrap) as HTMLElement | null;
      if (!wrap) return;
      const collapsed = wrap.classList.contains("card-body-wrap--collapsed");
      const btn = wrap.closest(".card")!.querySelector<HTMLElement>(".card-expand");
      if (collapsed) {
        wrap.classList.remove("card-body-wrap--collapsed");
        const h = wrap.scrollHeight || 200;
        wrap.style.maxHeight = h + "px";
        setTimeout(() => { wrap.style.maxHeight = ""; }, 350);
      } else {
        wrap.style.maxHeight = wrap.scrollHeight + "px";
        requestAnimationFrame(() => {
          wrap.style.maxHeight = "3em";
          wrap.classList.add("card-body-wrap--collapsed");
        });
        setTimeout(() => { wrap.style.maxHeight = ""; }, 350);
      }
      if (btn) btn.textContent = collapsed ? "收起 ▴" : "展开 ▾";
      return;
    }

    // 折叠板块
    const toggleBtn = t.closest(".section-toggle") as HTMLElement | null;
    if (toggleBtn) {
      const section = toggleBtn.closest(".section")!;
      const targets = section.querySelectorAll<HTMLElement>(".cards, .hero-card");
      const willCollapse = !targets[0]?.classList.contains("cards--hidden");
      targets.forEach(c => c.classList.toggle("cards--hidden", willCollapse));
      toggleBtn.textContent = willCollapse ? "▾" : "▴";
      toggleBtn.classList.toggle("section-toggle--collapsed", willCollapse);
    }
  });

  // ── 搜索 ──
  const searchInput = document.getElementById("searchInput") as HTMLInputElement;
  const searchClear = document.getElementById("searchClear") as HTMLElement;
  let searchTimer: ReturnType<typeof setTimeout>;

  function updateClearBtn() {
    searchClear.style.display = searchInput.value ? "flex" : "none";
  }

  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    updateClearBtn();
    const q = searchInput.value.trim();
    if (!q) {
      const current = location.hash.replace("#", "") || dates[0];
      if (current && dates.includes(current)) showDate(current);
      else if (current === "__faves__") renderFavesPage();
      return;
    }
    searchTimer = setTimeout(() => renderSearchResults(q), 300);
  });
  searchInput.addEventListener("keydown", e => {
    if (e.key === "Escape") {
      searchInput.value = "";
      updateClearBtn();
      searchInput.dispatchEvent(new Event("input"));
    }
  });
  searchClear.addEventListener("click", () => {
    searchInput.value = "";
    updateClearBtn();
    searchInput.dispatchEvent(new Event("input"));
    searchInput.focus();
  });

  // ── 搜索快捷键 `/` 或 ⌘K/Ctrl+K ──
  const searchKbd = document.getElementById("searchKbd");
  document.addEventListener("keydown", e => {
    const isSearchFocus = document.activeElement === searchInput;
    if ((e.key === "/" && !isSearchFocus) ||
        ((e.metaKey || e.ctrlKey) && e.key === "k")) {
      e.preventDefault();
      searchInput.focus();
      searchInput.select();
      if (searchKbd) searchKbd.style.display = "none";
    }
  });

  // ── 键盘导航 j/k/o/b ──
  let focusedCardIdx = -1;
  function getCards(): HTMLElement[] {
    return Array.from(document.querySelectorAll<HTMLElement>(".card, .hero-card"));
  }
  function focusCard(idx: number) {
    const cards = getCards();
    if (!cards.length) return;
    focusedCardIdx = Math.max(0, Math.min(idx, cards.length - 1));
    cards.forEach((c, i) => c.classList.toggle("card--focused", i === focusedCardIdx));
    cards[focusedCardIdx].scrollIntoView({ behavior: "smooth", block: "center" });
  }
  document.addEventListener("keydown", e => {
    const tag = (document.activeElement as HTMLElement)?.tagName;
    if (tag === "INPUT" || tag === "TEXTAREA") return;
    const cards = getCards();
    if (e.key === "j") { e.preventDefault(); focusCard(focusedCardIdx < 0 ? 0 : focusedCardIdx + 1); }
    else if (e.key === "k") { e.preventDefault(); focusCard(focusedCardIdx <= 0 ? 0 : focusedCardIdx - 1); }
    else if (e.key === "o" && focusedCardIdx >= 0) {
      const url = cards[focusedCardIdx]?.dataset.url;
      if (url) window.open(url, "_blank", "noopener");
    } else if (e.key === "b" && focusedCardIdx >= 0) {
      const url = cards[focusedCardIdx]?.dataset.url;
      if (url) {
        const now = toggleFave(url);
        // 更新按钮状态
        const btn = cards[focusedCardIdx].querySelector<HTMLElement>(".fave-btn");
        if (btn) { btn.textContent = now ? "★" : "☆"; btn.classList.toggle("faved", now); }
        showToast(now ? "⭐ 已收藏" : "取消收藏");
      }
    } else if (e.key === "?") {
      showToast("⌨️ j/k 上下浏览 · o 打开原文 · b 收藏 · / 搜索", 5000);
    }
  });

  // ── 离线 Toast ──
  function showToast(msg: string, duration = 3500) {
    let t = document.getElementById("offlineToast") as HTMLElement;
    if (!t) {
      t = document.createElement("div");
      t.id = "offlineToast";
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.classList.add("toast--show");
    setTimeout(() => t.classList.remove("toast--show"), duration);
  }
  window.addEventListener("offline", () => showToast("📡 已离线，显示缓存内容"));
  window.addEventListener("online",  () => showToast("✅ 网络已恢复"));

  // ── 阅读进度条 ──
  const progressBar = document.getElementById("readProgress");
  window.addEventListener("scroll", () => {
    if (!progressBar) return;
    const doc = document.documentElement;
    const scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight);
    progressBar.style.width = `${Math.min(100, scrolled * 100)}%`;
    // 同时驱动回到顶部按钮
    backTop.classList.toggle("visible", window.scrollY > 300);
  }, { passive: true });

  // ── 侧栏日期 hover 预览（tooltip） ──
  let tooltipEl: HTMLElement | null = null;
  function showDateTooltip(btn: HTMLElement, date: string) {
    const digest = cache[date];
    if (!digest?.summary) return;
    if (!tooltipEl) {
      tooltipEl = document.createElement("div");
      tooltipEl.className = "date-tooltip";
      document.body.appendChild(tooltipEl);
    }
    tooltipEl.textContent = digest.summary.slice(0, 80) + (digest.summary.length > 80 ? "…" : "");
    const rect = btn.getBoundingClientRect();
    tooltipEl.style.left = `${rect.right + 8}px`;
    tooltipEl.style.top  = `${rect.top}px`;
    tooltipEl.classList.add("date-tooltip--show");
  }
  function hideDateTooltip() {
    tooltipEl?.classList.remove("date-tooltip--show");
  }
  // tooltip 只在有精确指针的设备上生效（排除触摸屏）
  const hasPointer = window.matchMedia("(pointer: fine)").matches;
  if (hasPointer) {
    document.getElementById("sidebar")?.addEventListener("mouseover", e => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".date-btn");
      if (btn?.dataset.date) showDateTooltip(btn, btn.dataset.date);
    });
    document.getElementById("sidebar")?.addEventListener("mouseout", () => hideDateTooltip());
  }

  // ── AI 动态推荐问题（基于热词） ──
  function renderAiSuggestions(hotWords: Array<{word: string}>) {
    const box = document.getElementById("aiSuggestions");
    if (!box) return;
    const templates = [
      (w: string) => `${w}有什么最新进展？`,
      (w: string) => `${w}对我们有什么影响？`,
      (w: string) => `简单解释一下${w}`,
    ];
    const words = hotWords.slice(0, 3).map(h => h.word);
    const suggestions = words.map((w, i) => templates[i % templates.length](w));
    box.innerHTML = suggestions.map(s =>
      `<button class="ai-suggest-btn">${s}</button>`
    ).join("");
    box.querySelectorAll<HTMLElement>(".ai-suggest-btn").forEach(b => {
      b.addEventListener("click", () => {
        const aiInput = document.getElementById("aiInput") as HTMLInputElement;
        aiInput.value = b.textContent ?? "";
        submitAi();
        // 隐藏推荐
        box.style.display = "none";
        document.getElementById("aiHintMsg")?.remove();
      });
    });
  }

  // ── 移动端底部导航 ──
  const moreSheet = document.getElementById("mobMoreSheet")!;

  function scrollToSection(sec: string) {
    const target = document.getElementById(`sec-${sec}`);
    if (!target) return;
    const header = document.querySelector(".site-header") as HTMLElement;
    const secNav = document.getElementById("secNav") as HTMLElement;
    const offset = (header?.offsetHeight ?? 53) + (secNav?.offsetHeight ?? 45) + 8;
    window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - offset, behavior: "smooth" });
  }

  document.getElementById("mobileBottomNav")?.addEventListener("click", e => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>(".mob-nav-btn");
    if (!btn) return;
    if (btn.id === "mobNavMore") {
      moreSheet.classList.toggle("mob-more-sheet--open");
      btn.classList.toggle("active", moreSheet.classList.contains("mob-more-sheet--open"));
      return;
    }
    moreSheet.classList.remove("mob-more-sheet--open");
    document.getElementById("mobNavMore")?.classList.remove("active");
    const sec = btn.dataset.sec;
    if (!sec) return;
    scrollToSection(sec);
    document.querySelectorAll(".mob-nav-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  });

  moreSheet.addEventListener("click", e => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>(".mob-more-btn");
    if (!btn) return;
    const sec = btn.dataset.sec;
    if (!sec) return;
    moreSheet.classList.remove("mob-more-sheet--open");
    document.getElementById("mobNavMore")?.classList.remove("active");
    scrollToSection(sec);
  });

  // 点击其他区域关闭更多菜单
  document.addEventListener("click", e => {
    if (!moreSheet.classList.contains("mob-more-sheet--open")) return;
    const nav = document.getElementById("mobileBottomNav");
    if (!nav?.contains(e.target as Node) && !moreSheet.contains(e.target as Node)) {
      moreSheet.classList.remove("mob-more-sheet--open");
      document.getElementById("mobNavMore")?.classList.remove("active");
    }
  });

  // ── 滑动手势切日期 ──
  (function initSwipe() {
    let startX = 0, startY = 0, startTime = 0;
    const MIN_X = 60, MAX_Y = 80, MAX_MS = 400;

    document.addEventListener("touchstart", e => {
      const t = e.touches[0];
      startX = t.clientX; startY = t.clientY; startTime = Date.now();
    }, { passive: true });

    document.addEventListener("touchend", e => {
      // 不在 main 区域内忽略（避免与侧边栏/搜索冲突）
      const main = document.getElementById("main");
      if (!main?.contains(e.target as Node)) return;

      const t = e.changedTouches[0];
      const dx = t.clientX - startX;
      const dy = Math.abs(t.clientY - startY);
      const dt = Date.now() - startTime;

      if (Math.abs(dx) < MIN_X || dy > MAX_Y || dt > MAX_MS) return;

      const cur = dates.indexOf(location.hash.replace("#", "") || dates[0]);
      if (cur < 0) return;

      // 左滑 → 更早一天，右滑 → 更新一天
      if (dx < 0 && cur < dates.length - 1) {
        showDate(dates[cur + 1]);
        showToast(`← ${fmtDate(dates[cur + 1])}`);
      } else if (dx > 0 && cur > 0) {
        showDate(dates[cur - 1]);
        showToast(`→ ${fmtDate(dates[cur - 1])}`);
      }
    }, { passive: true });
  })();

  init();
</script>

<style is:global>
  /* ── Theme transition ── */
  *, *::before, *::after {
    transition: background-color 0.3s, border-color 0.3s, color 0.3s;
  }
  /* View Transitions：禁用默认淡入淡出，用圆形扩散 */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }
  ::view-transition-old(root) { z-index: 1; }
  ::view-transition-new(root) { z-index: 9999; }
  /* 但动画和变换不受影响 */
  .back-top, .main--fadein, .skeleton, .search-clear,
  .card-expand, .section-toggle, .sec-nav-btn, .date-btn {
    transition-property: background, border-color, color, opacity, transform, box-shadow;
  }
  .date-btn {
    display: flex; flex-direction: column;
    width: 100%; padding: 8px 10px 8px 12px;
    border-radius: 8px; background: none; border: none;
    color: var(--text2); font-size: 13px;
    text-align: left; cursor: pointer;
    transition: background 0.15s, color 0.15s; gap: 1px;
    position: relative;
  }
  .date-btn:hover { background: var(--bg3); color: var(--text); }
  .date-btn.active {
    background: rgba(231,76,60,0.12);
    color: var(--accent); font-weight: 700;
    border-left: 3px solid var(--accent);
    padding-left: 9px;
  }
  .date-btn.loading {
    opacity: 0.6;
    background: var(--bg3);
  }
  .date-btn.loading::after {
    content: '';
    display: inline-block; width: 8px; height: 8px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    border-top-color: transparent;
    animation: spin 0.6s linear infinite;
    margin-left: auto;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .date-sub { font-size: 10px; opacity: 0.6; font-weight: 400; }

  /* 返回今日 */
  .back-today-btn {
    display: block; width: calc(100% - 16px); margin: 0 8px 6px;
    padding: 6px 10px; border-radius: 8px;
    background: rgba(231,76,60,0.08); border: 1px dashed var(--accent);
    color: var(--accent); font-size: 12px; font-weight: 600;
    cursor: pointer; text-align: center;
  }
  .back-today-btn:hover { background: rgba(231,76,60,0.18); }
  @media (max-width: 680px) {
    .date-btn { flex-direction: row; align-items: center; width: auto; white-space: nowrap; padding: 6px 12px; gap: 4px; border-left: none !important; }
    .date-btn.active { background: var(--accent); color: #fff; padding-left: 12px; }
    .date-sub { display: none; }
  }

  /* ── Digest header ── */
  .digest-header {
    margin-bottom: 28px;
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 16px; padding: 18px 20px;
  }
  .digest-top {
    display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px;
  }
  .digest-title-row {
    display: flex; align-items: center; gap: 12px;
  }
  .digest-title {
    font-size: 22px; font-weight: 900; color: var(--accent);
    letter-spacing: -0.5px; line-height: 1.2;
  }
  .digest-title b { color: var(--heading); font-weight: 900; }
  .digest-badge {
    background: linear-gradient(135deg, var(--accent), #f59e0b);
    color: #fff; padding: 3px 14px; border-radius: 20px;
    font-size: 12px; font-weight: 700; letter-spacing: 0.03em;
    box-shadow: 0 2px 8px rgba(231,76,60,0.3);
  }
  /* ── Stats bar ── */
  .digest-stats {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px; color: var(--text3);
  }
  .stats-item { display: flex; align-items: baseline; gap: 3px; }
  .stats-num {
    font-size: 18px; font-weight: 800; color: var(--accent);
    font-variant-numeric: tabular-nums; line-height: 1;
  }
  .stats-label { font-size: 11px; color: var(--text3); }
  .stats-dot { opacity: 0.3; font-size: 16px; }
  .stats-update { font-size: 11px; color: var(--text3); opacity: 0.7; }

  /* ── Summary Hero ── */
  .digest-summary {
    position: relative;
    background: var(--summary-bg);
    border: 1px solid var(--summary-border); border-radius: 14px;
    padding: 0; overflow: hidden;
    margin-bottom: 0;
    list-style: none;
  }
  .digest-summary::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px; background: linear-gradient(to bottom, var(--accent), #f59e0b);
    border-radius: 14px 0 0 14px;
    pointer-events: none;
  }
  .digest-summary > summary { list-style: none; }
  .digest-summary > summary::-webkit-details-marker { display: none; }
  .digest-summary-toggle {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 18px 12px 24px;
    cursor: pointer; user-select: none;
    font-size: 11px; font-weight: 700; letter-spacing: 0.12em;
    color: var(--text3); text-transform: uppercase;
    transition: color 0.15s, background 0.15s;
  }
  .digest-summary-toggle:hover { color: var(--accent); background: rgba(231,76,60,0.04); }
  .digest-summary-arrow { font-size: 10px; transition: transform 0.25s ease; display: inline-block; }
  .digest-summary[open] .digest-summary-arrow { transform: rotate(180deg); }
  .digest-summary-text {
    font-size: 14px; font-weight: 400; color: var(--summary-text);
    line-height: 1.9; padding: 0 20px 16px 24px;
  }

  /* ── Section nav ── */
  .sec-nav {
    display: flex; gap: 6px; flex-wrap: wrap;
    margin-bottom: 28px; position: sticky;
    top: 53px; z-index: 100;
    background: color-mix(in srgb, var(--bg) 75%, transparent);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    padding: 10px 0 10px;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  }
  @media (max-width: 680px) {
    .sec-nav {
      flex-wrap: nowrap; overflow-x: auto;
      -webkit-overflow-scrolling: touch; scrollbar-width: none;
      padding: 8px 12px; gap: 6px;
    }
    .sec-nav::-webkit-scrollbar { display: none; }
  }
  .sec-nav-btn {
    padding: 5px 14px; border-radius: 20px;
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text2); font-size: 12px; font-weight: 500;
    text-decoration: none; transition: all 0.15s; white-space: nowrap;
    flex-shrink: 0; display: inline-flex; align-items: center; gap: 5px;
  }
  .sec-nav-btn:hover { background: var(--bg4); color: var(--text); border-color: var(--text3); text-decoration: none; }
  .sec-nav-btn.active {
    background: var(--accent); color: #fff;
    border-color: var(--accent); text-decoration: none;
    box-shadow: 0 2px 8px rgba(231,76,60,0.3);
  }
  .sec-nav-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 16px; height: 16px; border-radius: 8px;
    background: rgba(255,255,255,0.15); color: inherit;
    font-size: 10px; font-weight: 700; padding: 0 4px;
    line-height: 1;
  }
  .sec-nav-btn:not(.active) .sec-nav-badge {
    background: var(--bg4); color: var(--text3);
  }

  /* ── Section ── */
  .section { margin-bottom: 40px; margin-top: 8px; scroll-margin-top: 110px; }
  .section:first-of-type { margin-top: 0; }
  .section-title { font-size: 16px; font-weight: 700; color: var(--heading); letter-spacing: 0.02em; }
  .section-heading {
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 14px; padding: 10px 14px 10px 16px;
    border-radius: 10px;
    background: linear-gradient(90deg, color-mix(in srgb, var(--sec-color, #888) 10%, var(--bg2)) 0%, var(--bg2) 60%);
    border: 1px solid var(--border);
    border-left: 4px solid var(--sec-color, #888);
    cursor: default;
    transition: background 0.15s;
  }
  .section-heading:hover {
    background: linear-gradient(90deg, color-mix(in srgb, var(--sec-color, #888) 16%, var(--bg3)) 0%, var(--bg3) 60%);
  }
  .section-icon {
    font-size: 18px; line-height: 1;
    width: 32px; height: 32px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: color-mix(in srgb, var(--sec-color, #888) 15%, transparent);
    flex-shrink: 0;
  }
  .section-count { font-size: 11px; color: var(--text3); margin-left: 2px; }
  .section-toggle {
    margin-left: auto; background: none; border: none; cursor: pointer;
    color: var(--text3); font-size: 12px; padding: 3px 8px;
    border-radius: 6px; transition: color 0.15s, background 0.15s; flex-shrink: 0;
  }
  .section-toggle:hover { background: var(--bg4); color: var(--text); }
  .section-toggle--collapsed { color: var(--accent) !important; }

  /* ── Main fade-in ── */
  .main { flex: 1; min-width: 0; padding: 24px 28px 60px; transition: opacity 0.25s ease; }
  @media (max-width: 680px) { .main { padding: 14px 12px 40px; } }
  #contentCol { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  #sharedPanel { padding: 24px 28px 0; }
  @media (max-width: 680px) { #sharedPanel { padding: 14px 12px 0; } }
  .main--fadein { animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
  /* prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .main--fadein { animation: none; }
    .skeleton { animation: none; }
    .back-top { transition: opacity 0.1s; }
    *, *::before, *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }

  /* ── 今日看点 全宽 ── */
  .section--wide .cards--wide { display: flex; flex-direction: column; gap: 10px; }

  /* ── 双列卡片网格 ── */
  .cards--grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    align-items: stretch;
  }
  .cards--hidden { display: none !important; }
  @media (max-width: 900px) { .cards--grid { grid-template-columns: 1fr; } }

  /* ── Cards ── */
  /* .card 样式已移至文件末尾（含微放大效果） */
  /* placeholder */
  ._card_placeholder { display: none; }
  .card--job { border-left: 3px solid #f39c12; }
  .card--breaking { border-left: 3px solid #e74c3c; background: var(--breaking-bg); position: relative; overflow: hidden; }
  .card--breaking:hover { background: var(--breaking-hover); }
  .card--breaking::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: #e74c3c;
    animation: breakingPulse 2s ease-in-out infinite;
  }
  @keyframes breakingPulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 4px #e74c3c; }
    50% { opacity: 0.4; box-shadow: none; }
  }
  .card--major { border-left: 3px solid #e67e22; background: var(--major-bg); }
  .card--major:hover { background: var(--major-hover); }
  .card-title {
    font-size: 14px; font-weight: 600; color: var(--heading);
    margin-bottom: 7px; display: flex; align-items: flex-start;
    flex-wrap: wrap; gap: 6px;
  }
  .card-num {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 18px; height: 18px; border-radius: 4px;
    background: var(--accent); color: #fff;
    font-size: 10px; font-weight: 700; flex-shrink: 0;
    margin-top: 2px; line-height: 1;
  }
  .card-title a { color: var(--heading); text-decoration: none; }
  .card-title a:hover { color: var(--link); }
  .card-title-text { flex: 1; min-width: 0; }  /* 防止长标题溢出挤压 tag */
  .card-body { font-size: 13px; color: var(--text); line-height: 1.75; flex: 1; }
  .num-hl { color: var(--accent); font-weight: 700; }
  /* 平滑折叠包裹层 */
  .card-body-wrap {
    overflow: hidden;
    max-height: none;
    transition: max-height 0.35s ease;
    flex: 1;
  }
  .card-body-wrap--collapsed {
    max-height: 3em;
    -webkit-mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
    mask-image: linear-gradient(to bottom, #000 55%, transparent 100%);
  }
  .card-body--collapsed {
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }
  .card-footer {
    display: flex; align-items: center;
    justify-content: space-between; margin-top: 8px; gap: 8px;
  }
  .card-source {
    font-size: 11px; color: var(--text3); text-decoration: none;
    opacity: 0.65; transition: opacity 0.15s;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;
    display: flex; align-items: center; gap: 4px;
  }
  .card-source:hover { opacity: 1; color: var(--link); }
  .card-favicon { border-radius: 2px; flex-shrink: 0; vertical-align: middle; }
  .card-expand {
    font-size: 11px; color: var(--text3);
    background: none; border: none; cursor: pointer;
    padding: 0; white-space: nowrap; flex-shrink: 0;
    opacity: 0.55; transition: opacity 0.15s;
  }
  .card-expand:hover { opacity: 1; color: var(--accent); }
  .card-body-wrap--clickable { cursor: pointer; }
  .card-body-wrap--clickable:hover { opacity: 0.85; }

  /* ── Tags ── */
  .tag {
    display: inline-flex; align-items: center;
    padding: 2px 8px 2px 6px; border-radius: 5px;
    font-size: 10px; font-weight: 700; white-space: nowrap;
    flex-shrink: 0; margin-top: 1px; letter-spacing: 0.3px;
    border-left: 3px solid currentColor;
    opacity: 0.92;
  }
  .tag-breaking    { background: rgba(239,68,68,0.12);  color: #f87171; }
  .tag-major       { background: rgba(249,115,22,0.12); color: #fb923c; }
  .tag-analysis    { background: rgba(59,130,246,0.12); color: #60a5fa; }
  .tag-trend       { background: rgba(34,197,94,0.12);  color: #4ade80; }
  .tag-watch       { background: rgba(167,139,250,0.12);color: #a78bfa; }
  .tag-opportunity { background: rgba(16,185,129,0.12); color: #34d399; }
  .tag-alert       { background: rgba(234,179,8,0.12);  color: #facc15; }
  .tag-knowledge   { background: rgba(148,163,184,0.1); color: #94a3b8; }
  .tag-default     { background: rgba(148,163,184,0.1); color: #94a3b8; }
  /* light override */
  [data-theme="light"] .tag-breaking    { background: rgba(239,68,68,0.1);  color: #dc2626; }
  [data-theme="light"] .tag-major       { background: rgba(249,115,22,0.1); color: #ea580c; }
  [data-theme="light"] .tag-analysis    { background: rgba(59,130,246,0.1); color: #2563eb; }
  [data-theme="light"] .tag-trend       { background: rgba(34,197,94,0.1);  color: #16a34a; }
  [data-theme="light"] .tag-watch       { background: rgba(139,92,246,0.1); color: #7c3aed; }
  [data-theme="light"] .tag-opportunity { background: rgba(16,185,129,0.1); color: #059669; }
  [data-theme="light"] .tag-alert       { background: rgba(234,179,8,0.1);  color: #d97706; }
  [data-theme="light"] .tag-knowledge   { background: rgba(100,116,139,0.1);color: #475569; }
  [data-theme="light"] .tag-default     { background: rgba(100,116,139,0.1);color: #475569; }

  /* ── Skeleton ── */
  @keyframes shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position:  600px 0; }
  }
  .skeleton {
    border-radius: 8px;
    background: linear-gradient(90deg, var(--bg3) 25%, var(--bg4) 50%, var(--bg3) 75%);
    background-size: 1200px 100%;
    animation: shimmer 1.6s infinite linear;
    transition: none !important;  /* 防止全局 transition 干扰 shimmer */
  }
  .skeleton-wrap { padding: 0; }
  .skeleton-hero { height: 96px; margin-bottom: 20px; border-radius: 14px; }
  .skeleton-nav { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 24px; }
  .skeleton-pill { height: 28px; width: 80px; border-radius: 20px; }
  .skeleton-section { margin-bottom: 32px; }
  .skeleton-heading { height: 20px; width: 140px; margin-bottom: 12px; }
  .skeleton-card { height: 90px; margin-bottom: 10px; border-radius: var(--radius); }

  /* ── Back to top ── */
  .back-top {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--bg3); border: 1px solid var(--border); cursor: pointer;
    font-size: 18px; font-weight: 700; color: var(--text2); line-height: 1;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transform: scale(0.8);
    transition: opacity 0.25s, transform 0.25s, background 0.15s;
    pointer-events: none;
  }
  .back-top.visible { opacity: 1; transform: scale(1); pointer-events: auto; }
  .back-top:hover { background: var(--bg4); color: var(--accent); }

  /* ── Search ── */
  .search-result-header {
    font-size: 14px; color: var(--text2);
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .search-result-header b { color: var(--heading); }
  .card-meta { font-size: 11px; color: var(--text3); margin-bottom: 6px; }
  mark { background: rgba(231,76,60,0.2); color: var(--accent); border-radius: 2px; padding: 0 2px; }
  [data-theme="light"] mark { background: rgba(231,76,60,0.15); color: #b91c1c; }

  /* ── 今日看点卡片 hover ── */
  .section--wide .card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 20px rgba(231,76,60,0.1);
  }

  /* ── 离线 Toast ── */
  #offlineToast {
    position: fixed; bottom: 80px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: #1a1a1a; color: #fff;
    padding: 10px 20px; border-radius: 24px;
    font-size: 13px; font-weight: 500;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s, transform 0.3s;
    z-index: 9999; white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  #offlineToast.toast--show { opacity: 1; transform: translateX(-50%) translateY(0); }
  [data-theme="light"] #offlineToast { background: #333; }

  /* ── 英雄卡 ── */
  .hero-card {
    position: relative; overflow: hidden;
    background: var(--summary-bg);
    border: 1px solid var(--summary-border);
    border-radius: 14px;
    padding: 22px 24px 18px;
    margin-bottom: 12px;
    cursor: default;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .hero-card[data-url]:hover {
    border-color: var(--accent);
    box-shadow: 0 6px 28px rgba(231,76,60,0.15);
    transform: translateY(-2px);
  }
  .hero-tag-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .hero-label {
    font-size: 10px; font-weight: 800; letter-spacing: 0.12em;
    color: var(--accent); text-transform: uppercase;
    background: rgba(231,76,60,0.1); padding: 2px 8px; border-radius: 4px;
  }
  .hero-title {
    font-size: 20px; font-weight: 800; color: var(--heading);
    line-height: 1.4; margin-bottom: 10px;
  }
  .hero-body { font-size: 14px; color: var(--text); line-height: 1.8; margin-bottom: 14px; }
  .hero-footer { display: flex; align-items: center; justify-content: space-between; }
  .hero-source {
    font-size: 12px; color: var(--text3); text-decoration: none;
    display: flex; align-items: center; gap: 4px; opacity: 0.7;
    transition: opacity 0.15s;
  }
  .hero-source:hover { opacity: 1; color: var(--link); }

  /* ── 收藏按钮 ── */
  .fave-btn {
    font-size: 14px; background: none; border: none; cursor: pointer;
    color: var(--text3); padding: 0 2px; flex-shrink: 0;
    opacity: 0.5; transition: opacity 0.15s, color 0.15s, transform 0.15s;
    line-height: 1;
  }
  .fave-btn:hover { opacity: 1; transform: scale(1.2); }
  .fave-btn.faved { color: #f39c12; opacity: 1; }
  .fave-entry-btn {
    display: flex; align-items: center; gap: 6px;
    width: 100%; padding: 8px 10px 8px 12px;
    border-radius: 8px; background: none; border: none;
    color: var(--text2); font-size: 13px; text-align: left;
    cursor: pointer; transition: background 0.15s, color 0.15s;
    margin-bottom: 4px;
  }
  .fave-entry-btn:hover { background: var(--bg3); color: var(--text); }
  .fave-entry-btn.active { background: rgba(243,156,18,0.12); color: #f39c12; font-weight: 700; }
  .fave-count {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 16px; height: 16px; border-radius: 8px;
    background: #f39c12; color: #fff;
    font-size: 10px; font-weight: 700; padding: 0 4px; line-height: 1;
    margin-left: auto;
  }
  .faves-header {
    font-size: 15px; font-weight: 700; color: var(--heading);
    margin-bottom: 16px; padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  /* ── 热词云 ── */
  /* ── 天气 + 黄历 ── */
  /* ── 市场 + 节假日 + 黄历 容器 ── */
  .weather-almanac-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px; margin-top: 14px;
  }
  .weather-almanac-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  @media (max-width: 500px) {
    .weather-almanac-row-2 { grid-template-columns: 1fr; }
  }
  /* ── 市场快讯 ── */
  .market-block {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 14px; padding: 14px 16px;
  }
  .market-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .market-header-right { display: flex; align-items: center; gap: 10px; }
  .market-title { font-size: 13px; font-weight: 700; color: var(--heading); }
  .market-time { font-size: 10px; color: var(--text3); }
  .market-holiday { font-size: 11px; color: var(--text2); white-space: nowrap; }
  .market-holiday b { color: var(--accent); font-weight: 800; font-variant-numeric: tabular-nums; }
  .market-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 6px; }
  @media (max-width: 680px) { .market-grid { grid-template-columns: repeat(3,1fr); } }
  .market-item {
    display: flex; flex-direction: column; align-items: center; gap: 3px;
    background: var(--bg3); border-radius: 10px; padding: 8px 4px 7px;
    border: 1px solid transparent;
    transition: border-color 0.2s, transform 0.15s;
    cursor: default;
  }
  .market-item:hover { transform: translateY(-2px); }
  .market-item--up   { border-color: rgba(34,197,94,0.4); background: rgba(34,197,94,0.06); }
  .market-item--down { border-color: rgba(239,68,68,0.35); background: rgba(239,68,68,0.05); }
  .market-name { font-size: 10px; color: var(--text3); font-weight: 500; text-align: center; line-height: 1.2; }
  .market-val  { font-size: 13px; font-weight: 800; color: var(--heading); font-variant-numeric: tabular-nums; }
  .market-chg  { font-size: 11px; font-weight: 600; }
  .market-chg--up   { color: #22c55e; }
  .market-chg--down { color: #ef4444; }
  /* ── 黄历 ── */
  .almanac-block {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 14px; padding: 10px 14px;
    display: flex; flex-wrap: wrap; align-items: center; gap: 6px;
    font-size: 12px; margin-top: 8px;
  }
  .almanac-date { font-size: 12px; font-weight: 700; color: var(--heading); flex-shrink: 0; }
  .almanac-color { font-size: 11px; color: var(--text2); flex-shrink: 0; }
  .almanac-tags { display: flex; flex-wrap: wrap; gap: 4px; }
  .almanac-yi { font-size: 11px; background: rgba(34,197,94,0.12); color: #22c55e; border-radius: 6px; padding: 2px 7px; }
  .almanac-ji { font-size: 11px; background: rgba(239,68,68,0.1); color: #ef4444; border-radius: 6px; padding: 2px 7px; }
  .almanac-fortune { width: 100%; font-size: 11px; color: var(--text3); margin-top: 2px; font-style: italic; }

  /* ── 今日名言 ── */
  .daily-quote {
    margin: 0 0 22px;
    padding: 14px 18px 14px 20px;
    border-left: 4px solid var(--accent);
    background: linear-gradient(120deg, color-mix(in srgb, var(--accent) 8%, var(--bg2)) 0%, var(--bg2) 50%);
    border-radius: 0 14px 14px 0;
    display: flex; flex-direction: column; gap: 5px;
    position: relative; overflow: hidden;
  }
  .daily-quote::after {
    content: '"';
    position: absolute; right: 14px; top: -4px;
    font-size: 72px; line-height: 1; color: var(--accent); opacity: 0.08;
    font-family: Georgia, serif; pointer-events: none;
  }
  .quote-text {
    font-size: 16px; font-style: italic; color: var(--heading);
    margin: 0; line-height: 1.7; font-weight: 500;
  }
  .quote-zh     { font-size: 13px; color: var(--text2); font-style: normal; display: block; margin-top: 4px; }
  .quote-author { font-size: 11px; color: var(--text3); font-style: normal; }
  .quote-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 6px; }
  .quote-copy {
    font-size: 11px; color: var(--text3); background: none; border: 1px solid var(--border);
    border-radius: 6px; padding: 2px 8px; cursor: pointer; transition: all 0.15s;
  }
  .quote-copy:hover { color: var(--accent); border-color: var(--accent); }

  /* 热词高亮动画 */
  .card--highlighted {
    outline: 2px solid var(--accent) !important;
    box-shadow: 0 0 0 4px rgba(231,76,60,0.15), 0 6px 20px rgba(0,0,0,0.15) !important;
    animation: highlightPulse 0.4s ease;
  }
  @keyframes highlightPulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.02); }
    100% { transform: scale(1); }
  }

  /* 每日一问上期结果 */
  .dq-prev {
    margin-top: 12px; font-size: 12px; color: var(--text3);
    border-top: 1px solid var(--border); padding-top: 10px;
  }
  .dq-prev summary {
    cursor: pointer; user-select: none; color: var(--text2);
    list-style: none; display: flex; align-items: center; gap: 6px;
  }
  .dq-prev summary::before { content: '▶'; font-size: 9px; transition: transform 0.2s; }
  .dq-prev[open] summary::before { transform: rotate(90deg); }
  .dq-prev-bars { margin-top: 8px; display: flex; flex-direction: column; gap: 5px; }

  /* ── 今日时间轴 ── */
