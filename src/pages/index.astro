    </div>`;
  }

  // ── 客户端拉取实时行情 ──
  async function injectMarketData() {
    const SYMBOLS: {id:string; sym:string; type:string}[] = [
      {id:"沪指",    sym:"000001.SS", type:"index"},
      {id:"深指",    sym:"399001.SZ", type:"index"},
      {id:"纳指",    sym:"^IXIC",    type:"index"},
      {id:"恒生",    sym:"^HSI",     type:"index"},
      {id:"USD/CNY", sym:"CNY=X",    type:"fx"},
    ];

    const grid   = document.getElementById("marketGrid");
    const timeEl = document.getElementById("marketTime");
    if (!grid) return;

    const applyData = (data: Record<string, any>, source: string) => {
      let hit = 0;
      SYMBOLS.forEach(sym => {
        const entry = data[sym.sym];
        if (!entry) return;
        const closes = entry.close ?? [];
        const price  = closes[closes.length - 1] ?? 0;
        if (!price) return;
        const prev = entry.chartPreviousClose ?? price;
        const chg  = prev ? ((price - prev) / prev) * 100 : 0;
        const up   = chg >= 0;
        const item = grid!.querySelector<HTMLElement>(`.market-item[data-name="${sym.id}"]`);
        if (!item) return;
        item.querySelector<HTMLElement>(".market-val")!.textContent =
          sym.type === "fx" ? price.toFixed(4) : price >= 10000 ? (price/10000).toFixed(2)+"w" : price.toFixed(2);
        const chgEl = item.querySelector<HTMLElement>(".market-chg")!;
        chgEl.textContent = `${up ? "▲" : "▼"} ${Math.abs(chg).toFixed(2)}%`;
